{%- comment -%}
  HAUSTAS Brand Design System v2 -- Section 7.4
  Exit-intent (desktop) / 30-second dwell (mobile) first-visit email capture.
  Offer: 10% off first order (code WELCOME10). Styled like a product card:
  Mist background, hairline border, serif headline. Shows once per session.
{%- endcomment -%}

<div id="hs-welcome-offer" class="hs-welcome-offer" aria-hidden="true">
  <div class="hs-welcome-offer__backdrop" data-hs-welcome-close></div>
  <div class="hs-welcome-offer__card" role="dialog" aria-modal="true" aria-labelledby="hs-welcome-offer-heading">
    <button type="button" class="hs-welcome-offer__close" data-hs-welcome-close aria-label="Close">
      <svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M3 3l10 10M13 3L3 13" stroke="#5C6368" stroke-width="1.4" stroke-linecap="round"/></svg>
    </button>

    <div class="hs-welcome-offer__body" data-hs-welcome-step="form">
      <p class="hs-welcome-offer__eyebrow">Welcome</p>
      <h2 id="hs-welcome-offer-heading" class="hs-welcome-offer__heading">10% Off Your First Order</h2>
      <p class="hs-welcome-offer__text">Join the list for water care tips, new system updates, and 10% off to start.</p>

      {% form 'customer', id: 'hs-welcome-offer-form', class: 'hs-welcome-offer__form' %}
        {% if form.posted_successfully? %}
          <div data-hs-welcome-success>
            <p class="hs-welcome-offer__success-text">You're in. Your code:</p>
            <p class="hs-welcome-offer__code">WELCOME10</p>
            <p class="hs-welcome-offer__success-note">Use it at checkout, or <a href="/discount/WELCOME10">shop now and we'll apply it automatically</a>.</p>
          </div>
        {% else %}
          <input type="hidden" name="contact[tags]" value="newsletter,welcome-offer">
          <div class="hs-welcome-offer__field-row">
            <label for="hs-welcome-offer-email" class="visually-hidden">Email</label>
            <input
              type="email"
              name="contact[email]"
              id="hs-welcome-offer-email"
              class="hs-welcome-offer__input"
              placeholder="Email address"
              required
            >
            <button type="submit" class="hs-welcome-offer__submit">Get 10% Off</button>
          </div>
          {% if form.errors %}
            <p class="hs-welcome-offer__error">{{ form.errors.messages['email'] | default: "Please enter a valid email." }}</p>
          {% endif %}
        {% endif %}
      {% endform %}

      <button type="button" class="hs-welcome-offer__dismiss" data-hs-welcome-close>No thanks</button>
    </div>
  </div>
</div>

{% stylesheet %}
  .hs-welcome-offer {
    position: fixed;
    inset: 0;
    z-index: var(--layer-modal, 100);
    display: none;
  }

  .hs-welcome-offer.is-visible {
    display: block;
  }

  .hs-welcome-offer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(32, 34, 36, 0.4);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .hs-welcome-offer.is-visible .hs-welcome-offer__backdrop {
    opacity: 1;
  }

  .hs-welcome-offer__card {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -46%);
    width: min(400px, calc(100vw - 32px));
    background: #F1F4F3;
    border: 1px solid #C8D1CC;
    padding: 40px 32px 32px;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .hs-welcome-offer.is-visible .hs-welcome-offer__card {
    opacity: 1;
    transform: translate(-50%, -50%);
  }

  .hs-welcome-offer__close {
    position: absolute;
    top: 14px;
    right: 14px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    line-height: 0;
  }

  .hs-welcome-offer__eyebrow {
    margin: 0 0 8px;
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #0F5E75;
  }

  .hs-welcome-offer__heading {
    margin: 0 0 12px;
    font-family: var(--font-heading--family);
    font-size: 1.75rem;
    line-height: 1.15;
    color: #202224;
  }

  .hs-welcome-offer__text {
    margin: 0 0 20px;
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: #5C6368;
  }

  .hs-welcome-offer__field-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .hs-welcome-offer__input {
    flex: 1 1 180px;
    min-width: 0;
    padding: 12px 14px;
    border: 1px solid #C8D1CC;
    background: #FCFCFA;
    color: #202224;
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
  }

  .hs-welcome-offer__submit {
    flex: 1 1 100%;
    padding: 12px 16px;
    background: #0F5E75;
    color: #FFFFFF;
    border: none;
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .hs-welcome-offer__submit:hover {
    background: #0B4D60;
  }

  @media screen and (min-width: 480px) {
    .hs-welcome-offer__submit {
      flex: 0 0 auto;
    }
  }

  .hs-welcome-offer__error {
    margin: 8px 0 0;
    font-family: var(--font-body--family);
    font-size: 0.8125rem;
    color: #B65C4B;
  }

  .hs-welcome-offer__dismiss {
    display: block;
    margin: 16px auto 0;
    background: none;
    border: none;
    font-family: var(--font-body--family);
    font-size: 0.8125rem;
    color: #8B9398;
    text-decoration: underline;
    cursor: pointer;
  }

  .hs-welcome-offer__success-text {
    margin: 0 0 6px;
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
    color: #202224;
  }

  .hs-welcome-offer__code {
    margin: 0 0 10px;
    font-family: ui-monospace, 'SF Mono', 'Cascadia Code', 'Roboto Mono', Menlo, Consolas, monospace;
    font-size: 1.5rem;
    letter-spacing: 0.06em;
    color: #0F5E75;
    padding: 10px 14px;
    background: #EAF5F8;
    border: 1px dashed #B7CFD6;
    display: inline-block;
  }

  .hs-welcome-offer__success-note {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 0.8125rem;
    color: #5C6368;
  }

  .hs-welcome-offer__success-note a {
    color: #0F5E75;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    if (window.__hsWelcomeOfferInit) return;
    window.__hsWelcomeOfferInit = true;

    var modal = document.getElementById('hs-welcome-offer');
    if (!modal) return;

    var SESSION_KEY = 'hs_welcome_offer_shown';
    var FORM_SUBMITTED = modal.querySelector('[data-hs-welcome-success]') !== null;
    var sawBottomSignup = false;

    var bottomSignup = document.getElementById('shopify-section-email_capture_01');
    if (bottomSignup && 'IntersectionObserver' in window) {
      var signupObserver = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            sawBottomSignup = true;
            signupObserver.disconnect();
          }
        });
      }, { threshold: 0.3 });
      signupObserver.observe(bottomSignup);
    }

    function alreadyShown() {
      try {
        return sawBottomSignup || sessionStorage.getItem(SESSION_KEY) === '1' || localStorage.getItem('hs_welcome_offer_dismissed') === '1';
      } catch (e) {
        return sawBottomSignup;
      }
    }

    function markShown() {
      try {
        sessionStorage.setItem(SESSION_KEY, '1');
      } catch (e) {}
    }

    function show() {
      if (alreadyShown()) return;
      modal.classList.add('is-visible');
      modal.setAttribute('aria-hidden', 'false');
      markShown();
    }

    function hide() {
      modal.classList.remove('is-visible');
      modal.setAttribute('aria-hidden', 'true');
      try {
        localStorage.setItem('hs_welcome_offer_dismissed', '1');
      } catch (e) {}
    }

    modal.querySelectorAll('[data-hs-welcome-close]').forEach(function (el) {
      el.addEventListener('click', hide);
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.classList.contains('is-visible')) hide();
    });

    // If the form was just submitted (success state rendered server-side), show immediately
    if (FORM_SUBMITTED) {
      modal.classList.add('is-visible');
      modal.setAttribute('aria-hidden', 'false');
      markShown();
      return;
    }

    var isDesktop = window.matchMedia('(min-width: 750px)').matches;

    if (isDesktop) {
      document.addEventListener('mouseout', function (e) {
        if (!e.relatedTarget && e.clientY <= 0) {
          show();
        }
      });
    } else {
      window.setTimeout(show, 30000);
    }
  })();
{% endjavascript %}
