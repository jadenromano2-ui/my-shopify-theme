{% liquid
  assign bg = section.settings.background_color
  assign fg = section.settings.foreground_color
%}

<div
  class="section section--full-width closing-statement spacing-style"
  style="{% render 'spacing-style', settings: section.settings %} --cls-bg: {{ bg }}; --cls-fg: {{ fg }};"
  data-testid="closing-statement"
>
  <div class="closing-statement__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="closing-statement__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="closing-statement__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subtext != blank %}
      <p class="closing-statement__subtext">{{ section.settings.subtext }}</p>
    {% endif %}
    {% if section.settings.cta_label != blank %}
      <a href="{{ section.settings.cta_link | default: 'shopify://collections/all' }}" class="closing-statement__cta">
        {{ section.settings.cta_label }}
      </a>
    {% endif %}
  </div>
</div>

{% javascript %}
  (function () {
    if (window.__clsRevealInit) return;
    window.__clsRevealInit = true;

    const reduceMotion =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const target = document.querySelector('.closing-statement__inner');

    if (!target) return;

    if (reduceMotion || !('IntersectionObserver' in window)) {
      target.classList.add('is-visible');
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25, rootMargin: '0px 0px -8% 0px' }
    );

    io.observe(target);
  })();
{% endjavascript %}

{% stylesheet %}
  .closing-statement {
    background: var(--cls-bg, #2E2C29);
    color: var(--cls-fg, #FFFFFF);
  }

  .closing-statement__inner {
    max-width: 44rem;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 64px);
    text-align: center;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.9s var(--animation-timing-fade-in, ease), transform 0.9s var(--animation-timing-fade-in, ease);
  }

  .closing-statement__inner.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .closing-statement__eyebrow {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #2F5D62;
    margin: 0 0 18px;
  }

  .closing-statement__heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    line-height: 1.08;
    letter-spacing: -0.01em;
    margin: 0 0 18px;
  }

  .closing-statement__subtext {
    font-family: var(--font-body--family);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: #C9C6BC;
    margin: 0 auto 32px;
    max-width: 34rem;
  }

  .closing-statement__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 34px;
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2E2C29;
    background: #FFFFFF;
    text-decoration: none;
    border: 1px solid #FFFFFF;
    transition: background 0.25s ease, color 0.25s ease;
  }

  .closing-statement__cta:hover {
    background: transparent;
    color: #FFFFFF;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Closing statement",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "HAUSTAS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Precision, Delivered Quietly."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Every unit is engineered, tested, and finished by hand — built to disappear into your home for decades, not years."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#2E2C29"
    },
    {
      "type": "color",
      "id": "foreground_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Collection link"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link label",
      "default": "Explore The Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "Closing statement"
    }
  ]
}
{% endschema %}
