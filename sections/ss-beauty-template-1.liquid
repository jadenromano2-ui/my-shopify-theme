        background: #F3F3F3;
      }

      .listicle-tm-img-wrap-{{ block.id }} img,
      .listicle-tm-img-wrap-{{ block.id }} svg {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .listicle-tm-img-wrap-{{ block.id }} svg {
        background: #F3F3F3;
      }

      .listicle-tm-stars-{{ block.id }} {
        display: flex;
        gap: 2px;
        margin-bottom: 8px;
      }
      .listicle-tm-stars-{{ block.id }} svg,
      .listicle-tm-stars-{{ block.id }} img {
        display: block;
        width: {{ block.settings.stars_size }}px;
        height: {{ block.settings.stars_size }}px;
        flex-shrink: 0;
        object-fit: contain;
      }
      .listicle-tm-star-full-{{ block.id }} {
        fill: {{ block.settings.stars_color }};
      }
      .listicle-tm-star-empty-{{ block.id }} {
        fill: {{ block.settings.stars_color | color_modify: 'alpha', 0.2 }};
      }

      .listicle-tm-quote-{{ block.id }} {
        font-size: {{ text_size_mobile }}px;
        color: {{ block.settings.quote_color }};
        flex: 1;
      }
      .listicle-tm-quote-{{ block.id }} * { margin: 0; font-size: inherit; color: inherit; }
      @media(min-width: 1024px) {
        .listicle-tm-quote-{{ block.id }} { font-size: {{ text_size }}px; }
      }

      .listicle-tm-author-{{ block.id }} {
        display: block;
        font-size: {{ text_size_mobile }}px;
        color: {{ block.settings.author_color }};
        margin: 8px 0 0;
        font-weight: 600;
      }
      @media(min-width: 1024px) {
        .listicle-tm-author-{{ block.id }} { font-size: {{ text_size }}px; }
      }

      .listicle-tm-prev-{{ block.id }},
      .listicle-tm-next-{{ block.id }} {
        position: absolute;
        z-index: 2;
        top: 50%;
        transform: translateY(-50%);
        width: {{ section.settings.arrow_size_mobile }}px;
        height: {{ section.settings.arrow_size_mobile }}px;
        border-radius: {{ section.settings.arrow_radius }}px;
        border: {{ section.settings.arrow_border_thickness }}px solid {{ section.settings.arrow_border_color }};
        background: {{ section.settings.arrow_bg_color }};
        align-items: center;
        justify-content: center;
        cursor: pointer;
        -webkit-appearance: none;
        padding: 0;
        transition: all 0.3s ease;
        color: {{ section.settings.arrow_color }};
        display: none;
      }
      .listicle-tm-prev-{{ block.id }} { left: 10px; }
      .listicle-tm-next-{{ block.id }} { right: 10px; }
      {% unless section.settings.arrow_hover_effect == "color" %}
      .listicle-tm-prev-{{ block.id }}:hover,
      .listicle-tm-next-{{ block.id }}:hover {
        background: {{ section.settings.arrow_bg_color }} !important;
        border-color: {{ section.settings.arrow_border_color }} !important;
        color: {{ section.settings.arrow_color }} !important;
      }
      {% endunless %}
      .listicle-tm-prev-{{ block.id }}.swiper-button-disabled,
      .listicle-tm-next-{{ block.id }}.swiper-button-disabled,
      .listicle-tm-prev-{{ block.id }}.swiper-button-lock,
      .listicle-tm-next-{{ block.id }}.swiper-button-lock {
        display: none !important;
        opacity: 0 !important;
        visibility: hidden !important;
      }
      @media(min-width: 1024px) {
        .listicle-tm-prev-{{ block.id }},
        .listicle-tm-next-{{ block.id }} {
          display: {% if block.settings.arrows_desktop %}flex{% else %}none{% endif %};
          opacity: 0;
          pointer-events: none;
          width: {{ section.settings.arrow_size }}px;
          height: {{ section.settings.arrow_size }}px;
        }
        .listicle-tm-slider-wrap-{{ block.id }}:hover .listicle-tm-prev-{{ block.id }},
        .listicle-tm-slider-wrap-{{ block.id }}:hover .listicle-tm-next-{{ block.id }} {
          opacity: 1;
          pointer-events: all;
          transition: all 0.3s ease;
        }
      }

      .listicle-tm-dots-{{ block.id }} {
        margin-top: 16px;
        position: static !important;
        width: 100%;
        justify-content: center;
        align-items: center;
        display: {% if block.settings.dots_mobile %}flex{% else %}none{% endif %} !important;
        min-height: 12px;
        flex-wrap: wrap;
      }
      @media(min-width: 1024px) {
        .listicle-tm-dots-{{ block.id }} {
          display: {% if block.settings.dots_desktop %}flex{% else %}none{% endif %} !important;
        }
      }
      .listicle-tm-dots-{{ block.id }} .swiper-pagination-bullet {
        display: block;
        width: 8px;
        height: 8px;
        min-width: 8px;
        min-height: 8px;
        background-color: {{ block.settings.dots_color }} !important;
        border-radius: 50%;
        margin: 0 6px !important;
        transition: transform 0.25s ease, opacity 0.25s ease;
        opacity: 0.5 !important;
        flex: 0 0 auto;
        transform: scale(1);
      }
      .listicle-tm-dots-{{ block.id }} .swiper-pagination-bullet.swiper-pagination-bullet-active {
        opacity: 1 !important;
        transform: scale(1.5);
      }

    {% endcase %}
  {%- endstyle -%}
{% endfor %}

{% if section.settings.enable_button_hover_effect %}
  {%- style -%}
    .listicle-section-{{ section.id }} .listicle-directional-hover-btn {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      transition:
        color 0.25s ease,
        border-color 0.25s ease,
        box-shadow 0.25s ease,
        background 0.25s ease,
        bottom 0.5s ease;
    }

    .listicle-section-{{ section.id }} .listicle-directional-hover-btn::before {
      content: "";
      position: absolute;
      inset: -1px;
      z-index: -1;
      display: block;
      border-radius: inherit;
      background: var(--listicle-btn-hover-bg-color, {{ btn_bg_hover_color }});
      pointer-events: none;
      transform: translateX(-102%);
      transition: transform 0.38s cubic-bezier(0.65, 0, 0.35, 1);
    }

    .listicle-section-{{ section.id }} .listicle-directional-hover-btn[data-listicle-hover-side="right"]::before {
      transform: translateX(102%);
    }

    .listicle-section-{{ section.id }} .listicle-directional-hover-btn[data-listicle-hover-side="top"]::before {
      transform: translateY(-102%);
    }

    .listicle-section-{{ section.id }} .listicle-directional-hover-btn[data-listicle-hover-side="bottom"]::before {
      transform: translateY(102%);
    }

    .listicle-section-{{ section.id }} .listicle-directional-hover-btn.listicle-hover-active::before,
    .listicle-section-{{ section.id }} .listicle-directional-hover-btn:is(:hover, :focus-visible)::before {
      transform: translate(0, 0);
    }

    .listicle-section-{{ section.id }} .listicle-directional-hover-btn.listicle-hover-active,
    .listicle-section-{{ section.id }} .listicle-directional-hover-btn:is(:hover, :focus-visible) {
      color: var(--listicle-btn-hover-color, {{ btn_hover_color }}) !important;
      border-color: var(--listicle-btn-hover-border-color, {{ btn_border_hover_color }}) !important;
      background: var(--listicle-btn-base-bg-color, transparent) !important;
    }

    .listicle-section-{{ section.id }} .listicle-directional-hover-btn > * {
      position: relative;
      z-index: 1;
    }

    @media (min-width: 1024px) {
      .listicle-section-{{ section.id }} .listicle-directional-hover-btn[class*="listicle-fc-btn-"] {
        position: absolute;
      }

      .listicle-section-{{ section.id }} [class*="listicle-fc-variant-wrap-"] .listicle-directional-hover-btn[class*="listicle-fc-btn-"],
      .listicle-section-{{ section.id }} [class*="listicle-fc-overlay-"] .listicle-directional-hover-btn[class*="listicle-fc-btn-"] {
        position: relative;
        bottom: auto;
        left: auto;
        transform: none;
        width: 100%;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .listicle-section-{{ section.id }} .listicle-directional-hover-btn::before {
        transition: none;
      }
    }
  {%- endstyle -%}
{% endif %}

<div class="listicle-section-{{ section.id }} listicle-blocks-wrapper-{{ section.id }}">
  {% for block in section.blocks %}
    <div {{ block.shopify_attributes }}>
      {% case block.type %}
        {% when 'hero' %}
          {%- assign d_type = block.settings.desktop_media_type -%}
          {%- assign m_type = block.settings.mobile_media_type -%}
          {%- assign has_d_video = false -%}
          {%- assign has_m_video = false -%}
          {%- if d_type == 'video'
            and block.settings.desktop_video_source == 'uploaded'
            and block.settings.desktop_video != blank
          -%}
            {%- assign has_d_video = true -%}
          {%- endif -%}
          {%- if m_type == 'video'
            and block.settings.mobile_video_source == 'uploaded'
            and block.settings.mobile_video != blank
          -%}
            {%- assign has_m_video = true -%}
          {%- endif -%}

          <div class="listicle-hero-{{ block.id }}">
            {% if m_type != 'same' %}
              <div class="listicle-hero-media-{{ block.id }} listicle-hero-media-m-{{ block.id }}">
                {% if m_type == 'video' %}
                  {% if block.settings.mobile_video_source == 'uploaded' and block.settings.mobile_video != blank %}
                    <video class="listicle-video-m-{{ block.id }}" autoplay muted loop playsinline>
                      <source src="{{ block.settings.mobile_video.sources[1].url }}">
                    </video>
                  {% elsif block.settings.mobile_video_source == 'external'
                    and block.settings.mobile_video_url != blank
                  %}
                    {%- assign m_vid_id = block.settings.mobile_video_url.id -%}
                    {% if block.settings.mobile_video_url.type == 'youtube' %}
                      <iframe
                        src="https://www.youtube.com/embed/{{ m_vid_id }}?autoplay=1&mute=1&loop=1&playlist={{ m_vid_id }}&controls=0&modestbranding=1&rel=0"
                        allow="autoplay"
                        allowfullscreen
                        loading="lazy"
                      ></iframe>
                    {% elsif block.settings.mobile_video_url.type == 'vimeo' %}
                      <iframe
                        src="https://player.vimeo.com/video/{{ m_vid_id }}?autoplay=1&muted=1&loop=1&controls=0&rel=0"
                        allow="autoplay"
                        allowfullscreen
                        loading="lazy"
                      ></iframe>
                    {% endif %}
                  {% elsif block.settings.mobile_image != blank %}
                    {{
                      block.settings.mobile_image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'eager',
                        fetchpriority: 'high',
                        alt: block.settings.mobile_image.alt,
                        widths: '600, 800, 1200',
                        sizes: '100vw'
                    }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag }}
                  {% endif %}
                {% else %}
                  {% if block.settings.mobile_image != blank %}
                    {{
                      block.settings.mobile_image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'eager',
                        fetchpriority: 'high',
                        alt: block.settings.mobile_image.alt,
                        widths: '600, 800, 1200',
                        sizes: '100vw'
                    }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag }}
                  {% endif %}
                {% endif %}
              </div>
            {% endif %}

            <div class="listicle-hero-media-{{ block.id }}{% if m_type != 'same' %} listicle-hero-media-d-{{ block.id }}{% endif %}">
              {% if d_type == 'video' %}
                {% if block.settings.desktop_video_source == 'uploaded' and block.settings.desktop_video != blank %}
                  <video class="listicle-video-d-{{ block.id }}" autoplay muted loop playsinline>
                    <source src="{{ block.settings.desktop_video.sources[1].url }}">
                  </video>
                {% elsif block.settings.desktop_video_source == 'external'
                  and block.settings.desktop_video_url != blank
                %}
                  {%- assign d_vid_id = block.settings.desktop_video_url.id -%}
                  {% if block.settings.desktop_video_url.type == 'youtube' %}
                    <iframe
                      src="https://www.youtube.com/embed/{{ d_vid_id }}?autoplay=1&mute=1&loop=1&playlist={{ d_vid_id }}&controls=0&modestbranding=1&rel=0"
                      allow="autoplay"
                      allowfullscreen
                      loading="lazy"
                    ></iframe>
                  {% elsif block.settings.desktop_video_url.type == 'vimeo' %}
                    <iframe
                      src="https://player.vimeo.com/video/{{ d_vid_id }}?autoplay=1&muted=1&loop=1&controls=0&rel=0"
                      allow="autoplay"
                      allowfullscreen
                      loading="lazy"
                    ></iframe>
                  {% endif %}
                {% else %}
                  {% assign placeholder_video = 'https://cdn.shopify.com/videos/c/o/v/fbb140fd46e3429eba459e1549dbbe38.mp4' %}
                  <video class="listicle-video-d-{{ block.id }}" autoplay muted loop playsinline>
                    <source src="{{ placeholder_video }}">
                  </video>
                {% endif %}
              {% else %}
                {% if block.settings.desktop_image != blank %}
                  {%- capture desktop_sizes -%}
                    {%- if section.settings.width == 'full' -%}
                      100vw
                    {%- elsif section.settings.width == 'custom' -%}
                      (min-width: {{ section.settings.content_width }}px) {{ section.settings.content_width }}px, 100vw
                    {%- else -%}
                      (min-width: 1200px) 1200px, 100vw
                    {%- endif -%}
                  {%- endcapture -%}
                  {{
                    block.settings.desktop_image
                    | image_url: width: 2000
                    | image_tag:
                      loading: 'eager',
                      fetchpriority: 'high',
                      alt: block.settings.desktop_image.alt,
                      widths: '800, 1200, 1600, 2000',
                      sizes: desktop_sizes
                  }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag }}
                {% endif %}
              {% endif %}
            </div>

            <div class="listicle-hero-overlay-{{ block.id }}"></div>

            {% if has_d_video or has_m_video %}
              {% if block.settings.show_video_controls %}
                <div class="listicle-hero-controls-{{ block.id }}">
                  <button
                    class="listicle-hero-ctrl-{{ block.id }} listicle-play-btn-{{ block.id }}"
                    aria-label="Play / Pause"
                  >
                    <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
                      <path class="c-play"  d="m11.596 8.697-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393z"/>
                      <path class="c-pause" d="M5.5 3.5A1.5 1.5 0 0 1 7 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5zm5 0A1.5 1.5 0 0 1 12 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5z"/>
                    </svg>
                  </button>
                  {% unless block.settings.video_no_sound %}
                    <button
                      class="listicle-hero-ctrl-{{ block.id }} listicle-mute-btn-{{ block.id }}"
                      aria-label="Mute / Unmute"
                    >
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path class="c-muted"   d="M5.889 16H2a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1h3.889l5.294-4.332a.5.5 0 0 1 .817.387v15.89a.5.5 0 0 1-.817.387L5.89 16zm14.525-4 3.536 3.536-1.414 1.414L19 13.414l-3.536 3.536-1.414-1.414L17.586 12 14.05 8.464l1.414-1.414L19 10.586l3.536-3.536 1.414 1.414L20.414 12z"/>
                        <path class="c-unmuted" d="M5.889 16H2a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1h3.889l5.294-4.332a.5.5 0 0 1 .817.387v15.89a.5.5 0 0 1-.817.387L5.89 16zm13.517 4.134-1.416-1.416A8.978 8.978 0 0 0 21 12a8.982 8.982 0 0 0-3.304-6.968l1.42-1.42A10.976 10.976 0 0 1 23 12c0 3.223-1.386 6.122-3.594 8.134zm-3.543-3.543-1.422-1.422A3.993 3.993 0 0 0 16 12c0-1.43-.75-2.685-1.88-3.392l1.439-1.439A5.991 5.991 0 0 1 18 12c0 1.842-.83 3.49-2.137 4.591z"/>
                      </svg>
                    </button>
                  {% endunless %}
                </div>
              {% endif %}
            {% endif %}

            <div class="listicle-hero-content-{{ block.id }}">
              {% if block.settings.subheading != blank %}
                <div class="listicle-hero-subheading-{{ block.id }}">{{ block.settings.subheading }}</div>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h2 class="listicle-hero-heading-{{ block.id }}">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.text != blank %}
                <div class="listicle-hero-text-{{ block.id }}">{{ block.settings.text }}</div>
              {% endif %}
              {% if block.settings.btn_label != blank %}
                <a href="{{ block.settings.btn_url }}" class="listicle-hero-btn-{{ block.id }}">
                  {{- block.settings.btn_label -}}
                </a>
              {% endif %}
            </div>
          </div>

          {%- if has_d_video or has_m_video -%}
            {%- assign block_uid = block.id | replace: '-', '_' -%}
            <script>
              function initLst3Hero_{{ block_uid }}() {
                var hero = document.querySelector('.listicle-hero-{{ block.id }}');
                if (!hero || hero.dataset.lst3Init) return;
                hero.dataset.lst3Init = '1';
                var mq = window.matchMedia('(min-width: 1024px)');
                var playBtn = hero.querySelector('.listicle-play-btn-{{ block.id }}');
                var muteBtn = hero.querySelector('.listicle-mute-btn-{{ block.id }}');
                function getVideo() {
                  if (mq.matches) {
                    return hero.querySelector('.listicle-video-d-{{ block.id }}');
                  }
                  return hero.querySelector('.listicle-video-m-{{ block.id }}') || hero.querySelector('.listicle-video-d-{{ block.id }}');
                }
                if (playBtn) {
                  playBtn.addEventListener('click', function() {
                    var v = getVideo();
                    if (!v) return;
                    if (v.paused) { v.play(); playBtn.classList.remove('paused'); }
                    else          { v.pause(); playBtn.classList.add('paused'); }
                  });
                }
                if (muteBtn) {
                  muteBtn.addEventListener('click', function() {
                    var v = getVideo();
                    if (!v) return;
                    v.muted = !v.muted;
                    muteBtn.classList.toggle('unmuted', !v.muted);
                  });
                }
              }
              if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initLst3Hero_{{ block_uid }});
              } else { initLst3Hero_{{ block_uid }}(); }
              if (typeof Shopify !== 'undefined' && Shopify.designMode) {
                document.addEventListener('shopify:section:load', initLst3Hero_{{ block_uid }});
                document.addEventListener('shopify:block:select', function(e) {
                  if (e.detail && e.detail.blockId === '{{ block.id }}') initLst3Hero_{{ block_uid }}();
                });
              }
            </script>
          {%- endif -%}

        {% when 'featured_collection' %}
          {%- assign fc_coll = collections[block.settings.collection] -%}
          {%- assign block_uid = block.id | replace: '-', '_' -%}

          <div class="listicle-fc-{{ block.id }}">
            <div class="listicle-fc-inner-{{ block.id }}">
              <div class="listicle-fc-slider-wrap-{{ block.id }}">
                <div class="listicle-fc-slider-{{ block.id }} swiper">
                  <div class="swiper-wrapper">
                    {% if block.settings.collection != blank and fc_coll != blank %}
                      {% for product in fc_coll.products limit: block.settings.products_count %}
                        {%- assign fc_first_variant = product.selected_or_first_available_variant -%}
                        <div class="swiper-slide">
                          <div
                            class="listicle-fc-card-{{ block.id }}"
                            {% if product.media.size > 1 %}
                              data-has-second-image
                            {% endif %}
                          >
                            {%- capture fc_sizes -%}(min-width: 1024px) calc(100vw / {{ block.settings.columns }}), 100vw{%- endcapture -%}
                            <a
                              href="{{ product.url }}"
                              class="listicle-fc-img-layer-{{ block.id }} listicle-fc-first-img-{{ block.id }}"
                              aria-label="{{ product.title }}"
                            >
                              {% if product.featured_image != blank %}
                                {{
                                  product.featured_image
                                  | image_url: width: 800
                                  | image_tag: widths: '400, 600, 800', sizes: fc_sizes, alt: product.featured_image.alt
                                }}
                              {% else %}
                                {{ 'image' | placeholder_svg_tag }}
                              {% endif %}
                            </a>

                            {% if product.media.size > 1 %}
                              <a
                                href="{{ product.url }}"
                                class="listicle-fc-img-layer-{{ block.id }} listicle-fc-second-img-{{ block.id }}"
                                aria-label="{{ product.title }}"
                                tabindex="-1"
                              >
                                {% for media in product.media %}
                                  {% if forloop.index == 2 %}
                                    {{
                                      media
                                      | image_url: width: 800
                                      | image_tag: alt: media.alt, widths: '400, 600, 800', sizes: fc_sizes
                                    }}
                                  {% endif %}
                                {% endfor %}
                              </a>
                            {% endif %}

                            {% if block.settings.show_badge %}
                              {%- assign badge_text = '' -%}
                              {% for tag in product.tags %}
                                {% if tag contains 'badge:' %}
                                  {%- assign badge_text = tag | remove: 'badge:' | strip -%}
                                  {% break %}
                                {% endif %}
                              {% endfor %}
                              {% if badge_text == blank and product.compare_at_price > product.price %}
                                {%- assign badge_text = 'Sale' -%}
                              {% endif %}
                              {% if badge_text != blank %}
                                <span class="listicle-fc-badge-{{ block.id }}">{{ badge_text }}</span>
                              {% endif %}
                            {% endif %}

                            <div class="listicle-fc-content-{{ block.id }}">
                              <div class="listicle-fc-top-{{ block.id }}">
                                {% if block.settings.show_card_label %}
                                  {%- assign card_label = '' -%}
                                  {%- if block.settings.card_label_source == 'type' -%}
                                    {%- assign card_label = product.type -%}
                                  {%- elsif block.settings.card_label_source == 'vendor' -%}
                                    {%- assign card_label = product.vendor -%}
                                  {%- elsif block.settings.card_label_source == 'metafield' -%}
                                    {%- assign card_label = product.metafields.custom.label.value
                                      | default: product.metafields.custom.label
                                    -%}
                                  {%- else -%}
                                    {%- assign card_label = block.settings.card_label_custom -%}
                                  {%- endif -%}
                                  {% if card_label != blank %}
                                    <p class="listicle-fc-heading-{{ block.id }}">{{ card_label }}</p>
                                  {% endif %}
                                {% endif %}
                              </div>
                              <div class="listicle-fc-bottom-{{ block.id }}">
                                <div class="listicle-fc-bottom-inner-{{ block.id }}">
                                  <div class="listicle-fc-title-row-{{ block.id }}">
                                    <p class="listicle-fc-product-title-{{ block.id }}">{{ product.title }}</p>
                                    <p class="listicle-fc-price-{{ block.id }}">{{ product.price | money }}</p>
                                  </div>
                                  {%- assign tagline = product.metafields.custom.tagline.value
                                    | default: product.metafields.custom.tagline
                                  -%}
                                  {% if block.settings.show_text and tagline != blank %}
                                    <div class="listicle-fc-desc-{{ block.id }}">
                                      {{ tagline }}
                                    </div>
                                  {% endif %}
                                </div>
                                {% if block.settings.show_atc and block.settings.btn_label != blank %}
                                  <div
                                    class="listicle-fc-variant-wrap-{{ block.id }}"
