{{ 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css' | stylesheet_tag: preload: true }}
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

{%- liquid
  assign heading_size = section.settings.heading_size
  assign heading_size_mobile = section.settings.heading_size_mobile

  assign text_size = section.settings.text_size
  assign text_size_mobile = section.settings.text_size_mobile

  assign btn_size = section.settings.btn_size
  assign btn_size_mobile = section.settings.btn_size_mobile
  assign btn_color = section.settings.btn_color
  assign btn_hover_color = section.settings.btn_hover_color
  assign btn_bg_color = section.settings.btn_bg_color
  assign btn_bg_hover_color = section.settings.btn_bg_hover_color
  assign btn_border_color = section.settings.btn_border_color
  assign btn_border_hover_color = section.settings.btn_border_hover_color
  assign btn_border_thickness = section.settings.btn_border_thickness
  assign btn_radius = section.settings.btn_radius
  assign btn_padding_vertical = section.settings.btn_padding_vertical
  assign btn_padding_vertical_mobile = section.settings.btn_padding_vertical_mobile
  assign btn_padding_horizontal = section.settings.btn_padding_horizontal
  assign btn_padding_horizontal_mobile = section.settings.btn_padding_horizontal_mobile

  assign section_radius = section.settings.section_radius
  assign section_radius_mobile = section_radius | times: 0.6 | round: 0

  assign global_background_color = section.settings.background_color
  assign global_background_image = 'none'
  if section.settings.bg_style == 'gradient' and section.settings.background_gradient != blank
    assign global_background_image = section.settings.background_gradient
  endif
-%}

{%- style -%}
  .listicle-section-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.block_gap_mobile }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }
  @media(min-width: 1024px) {
    .listicle-section-{{ section.id }} {
      gap: {{ section.settings.block_gap }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  .listicle-section-{{ section.id }} [class*="-heading"],
  .listicle-section-{{ section.id }} [class*="fp-title"],
  .listicle-section-{{ section.id }} [class*="fc-product-title"],
  .listicle-section-{{ section.id }} [class*="fp-counter"],
  .listicle-section-{{ section.id }} [class*="tc-tab"] {
    line-height: {{ section.settings.heading_line_height }}%;
  }

  .listicle-section-{{ section.id }} [class*="-quote"],
  .listicle-section-{{ section.id }} [class*="-desc"],
  .listicle-section-{{ section.id }} [class*="fp-text"],
  .listicle-section-{{ section.id }} [class*="-author"],
  .listicle-section-{{ section.id }} [class*="hero-subheading"],
  .listicle-section-{{ section.id }} [class*="hero-text"],
  .listicle-section-{{ section.id }} [class*="iwt-text"],
  .listicle-section-{{ section.id }} [class*="fc-price"],
  .listicle-section-{{ section.id }} [class*="fc-badge"],
  .listicle-section-{{ section.id }} [class*="tc-text"],
  .listicle-section-{{ section.id }} [class*="tm-text"] {
    line-height: {{ section.settings.text_line_height }}%;
  }

  .listicle-section-{{ section.id }} [class*="-btn"] {
    line-height: {{ section.settings.button_line_height }}%;
  }
  .listicle-section-{{ section.id }} {
    --listicle-btn-base-bg-color: {{ btn_bg_color }};
    --listicle-btn-hover-bg-color: {{ btn_bg_hover_color }};
    --listicle-btn-hover-color: {{ btn_hover_color }};
    --listicle-btn-hover-border-color: {{ btn_border_hover_color }};
  }

  {% if section.settings.heading_custom_font %}
    {{ section.settings.heading_font | font_face: font_display: 'swap' }}
    .listicle-section-{{ section.id }} [class*="-heading"],
    .listicle-section-{{ section.id }} [class*="fp-title"],
    .listicle-section-{{ section.id }} [class*="fc-product-title"],
    .listicle-section-{{ section.id }} [class*="fp-counter"],
    .listicle-section-{{ section.id }} [class*="tc-tab"] {
      font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
      font-weight: {{ section.settings.heading_font.weight }};
      font-style: {{ section.settings.heading_font.style }};
    }
  {% endif %}
  {% if section.settings.text_custom_font %}
    {{ section.settings.text_font | font_face: font_display: 'swap' }}
    .listicle-section-{{ section.id }} [class*="-quote"],
    .listicle-section-{{ section.id }} [class*="-desc"],
    .listicle-section-{{ section.id }} [class*="fp-text"],
    .listicle-section-{{ section.id }} [class*="-author"],
    .listicle-section-{{ section.id }} [class*="hero-subheading"],
    .listicle-section-{{ section.id }} [class*="hero-text"],
    .listicle-section-{{ section.id }} [class*="fc-badge"],
    .listicle-section-{{ section.id }} [class*="fc-price"],
    .listicle-section-{{ section.id }} [class*="fc-variant-select"],
    .listicle-section-{{ section.id }} [class*="fc-overlay-title"],
    .listicle-section-{{ section.id }} [class*="iwt-text"],
    .listicle-section-{{ section.id }} [class*="tc-text"],
    .listicle-section-{{ section.id }} [class*="iwt-marquee-item"],
    .listicle-section-{{ section.id }} [class*="tm-text"] {
      font-family: {{ section.settings.text_font.family }}, {{ section.settings.text_font.fallback_families }};
      font-weight: {{ section.settings.text_font.weight }};
      font-style: {{ section.settings.text_font.style }};
    }
  {% endif %}
  {% if section.settings.button_custom_font %}
    {{ section.settings.button_font | font_face: font_display: 'swap' }}
    .listicle-section-{{ section.id }} [class*="-btn"] {
      font-family: {{ section.settings.button_font.family }}, {{ section.settings.button_font.fallback_families }};
      font-weight: {{ section.settings.button_font.weight }};
      font-style: {{ section.settings.button_font.style }};
    }
  {% endif %}
  {% for block in section.blocks %}
    {% if block.type == 'image_with_text' and block.settings.show_marquee and block.settings.marquee_custom_font %}
      {{ block.settings.marquee_font | font_face: font_display: 'swap' }}
      .listicle-section-{{ section.id }} .listicle-iwt-marquee-item-{{ block.id }} {
        font-family: {{ block.settings.marquee_font.family }}, {{ block.settings.marquee_font.fallback_families }} !important;
        font-weight: {{ block.settings.marquee_font.weight }} !important;
        font-style: {{ block.settings.marquee_font.style }} !important;
      }
    {% endif %}
  {% endfor %}

  .listicle-section-{{ section.id }} button[class*="-prev-"] .animate-icon,
  .listicle-section-{{ section.id }} button[class*="-next-"] .animate-icon {
    pointer-events: none;
    place-items: center;
    display: grid;
  }
  .listicle-section-{{ section.id }} button[class*="-prev-"] .animate-icon:before,
  .listicle-section-{{ section.id }} button[class*="-next-"] .animate-icon:before {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: {{ section.settings.arrow_icon_size_mobile | times: 0.8 }}px;
    height: {{ section.settings.arrow_icon_size_mobile | times: 0.8 }}px;
    transform: rotate(calc(1 * 45deg));
    box-sizing: border-box;
    border-style: solid;
    border: 0px;
    border-right: 2px solid currentColor;
    border-top: 2px solid currentColor;
    position: relative;
    left: -1px;
  }
  .listicle-section-{{ section.id }} button[class*="-prev-"] .animate-icon:before {
    left: unset;
    right: -1px;
    border-right: 0px;
    border-top: 0px;
    border-bottom: 2px solid currentColor;
    border-left: 2px solid currentColor;
  }
  .listicle-section-{{ section.id }} button[class*="-prev-"] .animate-icon:after,
  .listicle-section-{{ section.id }} button[class*="-next-"] .animate-icon:after {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: {{ section.settings.arrow_icon_size_mobile }}px;
    height: 1.6px;
    transform-origin: center;
    opacity: 0;
    background: currentColor;
    transform: scaleX(.5);
  }
  @media(min-width: 1024px) {
    .listicle-section-{{ section.id }} button[class*="-prev-"] .animate-icon:before,
    .listicle-section-{{ section.id }} button[class*="-next-"] .animate-icon:before {
      width: {{ section.settings.arrow_icon_size | times: 0.8 }}px;
      height: {{ section.settings.arrow_icon_size | times: 0.8 }}px;
    }
    .listicle-section-{{ section.id }} button[class*="-prev-"] .animate-icon:after,
    .listicle-section-{{ section.id }} button[class*="-next-"] .animate-icon:after {
      width: {{ section.settings.arrow_icon_size }}px;
    }
  }

  {% if section.settings.arrow_hover_effect == "color" %}
    .listicle-section-{{ section.id }} button[class*="-prev-"]:hover,
    .listicle-section-{{ section.id }} button[class*="-next-"]:hover {
      transition: all 0.3s ease 0s;
      border: {{ section.settings.arrow_border_thickness }}px solid {{ section.settings.arrow_border_hover_color }} !important;
      background: {{ section.settings.arrow_bg_hover_color }} !important;
    }
    .listicle-section-{{ section.id }} button[class*="-prev-"]:hover .animate-icon,
    .listicle-section-{{ section.id }} button[class*="-next-"]:hover .animate-icon {
      color: {{ section.settings.arrow_hover_color }};
    }
  {% elsif section.settings.arrow_hover_effect == "scale" %}
    .listicle-section-{{ section.id }} button[class*="-prev-"]:hover,
    .listicle-section-{{ section.id }} button[class*="-next-"]:hover {
      transform: translateY(-50%) scale(0.9);
      transition: background 0.25s, border-color 0.25s, transform 0.25s;
    }
  {% elsif section.settings.arrow_hover_effect == "arrow" %}
    .listicle-section-{{ section.id }} button[class*="-next-"]:hover .animate-icon:before {
      transform: translate(calc(1 * 0.125rem)) rotate(calc(1 * 45deg));
    }
    .listicle-section-{{ section.id }} button[class*="-prev-"]:hover .animate-icon:before {
      transform: translate(calc(-1 * 0.125rem)) rotate(calc(1 * 45deg));
    }
    .listicle-section-{{ section.id }} button[class*="-prev-"]:hover .animate-icon:after,
    .listicle-section-{{ section.id }} button[class*="-next-"]:hover .animate-icon:after {
      opacity: 1;
      transform: scaleX(1);
    }
  {% endif %}

  .listicle-section-{{ section.id }} .listicle-global-btn-inner {
    margin: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-decoration: none;
  }
  .listicle-atc-error {
    display: flex;
    align-items: flex-start;
    font-size: 1.3rem;
    line-height: 1.4;
    letter-spacing: 0.04rem;
    color: #EB001B;
  }
  .listicle-atc-error.hidden {
    display: none;
  }
  .listicle-atc-error__svg-wrapper {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    margin-right: 0.7rem;
    margin-top: 0.25rem;
  }
  .listicle-atc-error__icon {
    height: 100%;
    width: 100%;
  }
  .listicle-atc-error__message {
    display: flex;
    align-items: flex-start;
    font-size: 1.3rem;
    line-height: 1.4;
    letter-spacing: 0.04rem;
    margin-bottom: 1.5rem;
  }

  {% if section.settings.enable_animation %}
    @keyframes listicle-fade-up {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .listicle-blocks-wrapper-{{ section.id }} > * {
      opacity: 0;
    }
    .listicle-blocks-wrapper-{{ section.id }} > *.listicle-animated {
      animation: listicle-fade-up 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
  {% endif %}
{%- endstyle -%}

{% for block in section.blocks %}
  {%- liquid
    assign block_background_color = global_background_color
    assign block_background_image = global_background_image

    if block.settings.bg_style == 'gradient' and block.settings.background_gradient != blank
      assign block_background_image = block.settings.background_gradient
    elsif block.settings.background_color != blank
      assign block_background_color = block.settings.background_color
      assign block_background_image = 'none'
    endif
  -%}
  {%- style -%}
    {% case block.type %}
      {% when 'hero' %}
        {%- assign ctrl_bg_op = block.settings.ctrl_bg_opacity | divided_by: 100.0 -%}
        {%- assign ctrl_bd_op = block.settings.ctrl_border_opacity | divided_by: 100.0 -%}
        {%- assign overlay_alpha = block.settings.overlay_opacity | divided_by: 100.0 -%}

        .listicle-hero-{{ block.id }} {
          position: relative;
          overflow: hidden;
          height: {% if block.settings.height == 'full_screen' %}100vh{% elsif block.settings.height == 'fixed_height' %}{{ block.settings.height_custom_mobile }}px{% else %}auto{% endif %};
          background: #f3f3f3;
          border-radius: {{ section_radius_mobile }}px;
          {% if section.settings.width == 'full' %}
            margin: 0 {{ section.settings.margin_horizontal_mobile }}rem;
          {% elsif section.settings.width == 'custom' %}
            max-width: min({{ section.settings.content_width }}px, calc(100% - {{ section.settings.margin_horizontal_mobile | times: 2 }}rem));
            margin: 0 auto;
          {% else %}
            max-width: clamp(100px, var(--page-content-width, var(--page-width)), calc(100% - {{ section.settings.margin_horizontal_mobile | times: 2 }}rem));
            margin: 0 auto;
          {% endif %}
        }
        @media(min-width: 1024px) {
          .listicle-hero-{{ block.id }} {
            height: {% if block.settings.height == 'full_screen' %}100vh{% elsif block.settings.height == 'fixed_height' %}{{ block.settings.height_custom }}px{% else %}auto{% endif %};
            border-radius: {{ section_radius }}px;
            {% if section.settings.width == 'full' %}
              margin: 0 {{ section.settings.margin_horizontal }}rem;
            {% elsif section.settings.width == 'custom' %}
              max-width: min({{ section.settings.content_width }}px, calc(100% - {{ section.settings.margin_horizontal | times: 2 }}rem));
              margin: 0 auto;
            {% else %}
              max-width: clamp(100px, var(--page-content-width, var(--page-width)), calc(100% - {{ section.settings.margin_horizontal | times: 2 }}rem));
              margin: 0 auto;
            {% endif %}
          }
        }

        .listicle-hero-media-{{ block.id }} {
          position: absolute;
          inset: 0;
        }
        .listicle-hero-media-{{ block.id }} img,
        .listicle-hero-media-{{ block.id }} video,
        .listicle-hero-media-{{ block.id }} svg {
          display: block;
          width: 100%;
          height: 100%;
          object-fit: cover;
        }
        .listicle-hero-media-{{ block.id }} iframe {
          position: absolute;
          top: 50%;
          left: 50%;
          width: 177.78vh;
          height: 56.25vw;
          min-width: 100%;
          min-height: 100%;
          transform: translate(-50%, -50%);
          border: 0;
          pointer-events: none;
        }

        {% if block.settings.mobile_media_type != 'same' %}
          .listicle-hero-media-d-{{ block.id }} { display: none; }
          .listicle-hero-media-m-{{ block.id }} { display: block; }
          @media(min-width: 1024px) {
            .listicle-hero-media-d-{{ block.id }} { display: block; }
            .listicle-hero-media-m-{{ block.id }} { display: none; }
          }
        {% endif %}

        .listicle-hero-overlay-{{ block.id }} {
          display: block !important;
          position: absolute;
          inset: 0;
        background: {{ block.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};
          pointer-events: none;
          z-index: 1;
        }

        .listicle-hero-content-{{ block.id }} {
          {% if block.settings.height == 'auto' %}
            position: relative;
          {% else %}
            position: absolute;
          {% endif %}
          width: 100%;
          z-index: 2;
          color: {{ block.settings.text_color }};
          box-sizing: border-box;
          {% if section.settings.width == 'full' %}
            max-width: calc(100% - {{ section.settings.padding_horizontal_mobile | times: 2 }}rem);
          {% elsif section.settings.width == 'custom' %}
            max-width: min({{ section.settings.content_width }}px, calc(100% - {{ section.settings.padding_horizontal_mobile | times: 2 }}rem));
          {% else %}
            max-width: clamp(100px, var(--page-content-width, var(--page-width)), calc(100% - {{ section.settings.padding_horizontal_mobile | times: 2 }}rem));
          {% endif %}
          padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px {{ section.settings.padding_horizontal_mobile }}rem {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
          {% if block.settings.height == 'auto' %}
            {% case block.settings.content_position %}
              {% when 'bottom-center' %} margin: 0 auto; text-align: center;
              {% when 'center' %}        margin: 0 auto; text-align: center;
              {% when 'bottom-right' %}  margin: 0 0 0 auto; text-align: right;
            {% endcase %}
          {% else %}
            {% case block.settings.content_position %}
              {% when 'bottom-left' %}   bottom: 0; left: 0;
              {% when 'bottom-center' %} bottom: 0; left: 50%; transform: translateX(-50%); text-align: center;
              {% when 'bottom-right' %}  bottom: 0; right: 0; text-align: right;
              {% when 'center' %}        top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center;
              {% when 'top-left' %}      top: 0; left: 0;
            {% endcase %}
          {% endif %}
        }
        @media(min-width: 1024px) {
          .listicle-hero-content-{{ block.id }} {
            max-width: min({{ block.settings.content_max_width }}px, calc(100% - {{ section.settings.padding_horizontal | times: 2 }}rem));
            padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}rem {{ section.settings.padding_bottom }}px;
          }
        }

        .listicle-hero-subheading-{{ block.id }} {
          font-size: {{ text_size_mobile }}px;
          margin: 0 0 8px;
          color: {{ block.settings.subheading_color }};
        }
        @media(min-width: 1024px) {
          .listicle-hero-subheading-{{ block.id }} {
            font-size: {{ text_size }}px;
          }
        }

        .listicle-hero-heading-{{ block.id }} {
          font-size: {{ heading_size_mobile }}px;
          margin: 0 0 12px;
          color: {{ block.settings.heading_color }};
        }
        @media(min-width: 1024px) {
          .listicle-hero-heading-{{ block.id }} {
            font-size: {{ heading_size }}px;
          }
        }

        .listicle-hero-text-{{ block.id }} {
          font-size: {{ text_size_mobile }}px;
          margin: 0 0 16px;
        }
        @media(min-width: 1024px) {
          .listicle-hero-text-{{ block.id }} {
            font-size: {{ text_size }}px;
          }
        }

        .listicle-hero-btn-{{ block.id }} {
          display: inline-block;
          text-decoration: none;
          font-size: {{ btn_size_mobile }}px;
          color: {{ block.settings.btn_color }};
          border-radius: {{ btn_radius }}px;
          transition: background 0.25s, color 0.25s, border-color 0.25s;
          {% assign hero_btn_style = block.settings.btn_style %}
          {% if hero_btn_style == 'link' %}
            --listicle-btn-base-bg-color: transparent;
            --listicle-btn-hover-bg-color: transparent;
          {% else %}
            --listicle-btn-base-bg-color: {{ block.settings.btn_bg_color }};
            --listicle-btn-hover-bg-color: {{ block.settings.btn_bg_hover_color }};
          {% endif %}
          --listicle-btn-hover-color: {{ block.settings.btn_hover_color }};
          --listicle-btn-hover-border-color: {{ block.settings.btn_border_hover_color }};
          {% if hero_btn_style == 'outline' %}
            background: {{ block.settings.btn_bg_color }};
            border: {{ btn_border_thickness }}px solid {{ block.settings.btn_border_color }};
            padding: {{ btn_padding_vertical_mobile }}px {{ btn_padding_horizontal_mobile }}px;
          {% elsif hero_btn_style == 'link' %}
            background: transparent;
            border: 0;
            padding: 0;
          {% else %}
            background: {{ block.settings.btn_bg_color }};
            border: 0;
            padding: {{ btn_padding_vertical_mobile }}px {{ btn_padding_horizontal_mobile }}px;
          {% endif %}
        }
        .listicle-hero-btn-{{ block.id }}:hover {
          color: {{ block.settings.btn_hover_color }};
          {% if hero_btn_style == 'outline' %}
            background: {{ block.settings.btn_bg_hover_color }};
            border-color: {{ block.settings.btn_border_hover_color }};
          {% elsif hero_btn_style != 'link' %}
            background: {{ block.settings.btn_bg_hover_color }};
          {% endif %}
        }
        @media(min-width: 1024px) {
          .listicle-hero-btn-{{ block.id }} {
            font-size: {{ btn_size }}px;
            {% unless hero_btn_style == 'link' %}
              padding: {{ btn_padding_vertical }}px {{ btn_padding_horizontal }}px;
            {% endunless %}
          }
        }

        .listicle-hero-controls-{{ block.id }} {
          position: absolute;
          top: 14px;
          right: 14px;
          z-index: 3;
          display: flex;
          gap: 8px;
          align-items: center;
        }
        .listicle-hero-ctrl-{{ block.id }} {
          width: {{ block.settings.ctrl_size }}px;
          height: {{ block.settings.ctrl_size }}px;
          border-radius: 50%;
        border: {{ block.settings.ctrl_border_thickness }}px solid {{ block.settings.ctrl_border | color_modify: 'alpha', ctrl_bd_op }};
        background: {{ block.settings.ctrl_bg | color_modify: 'alpha', ctrl_bg_op }};
          display: flex;
          align-items: center;
          justify-content: center;
          cursor: pointer;
          transition: background 0.25s, border-color 0.25s;
          box-shadow: 0 0 10px rgba(0,0,0,.2);
          -webkit-appearance: none;
          backdrop-filter: blur(8px);
          -webkit-backdrop-filter: blur(8px);
        }
        .listicle-hero-ctrl-{{ block.id }} svg {
          display: block;
          width: {{ block.settings.ctrl_size | times: 0.45 | round }}px;
          height: {{ block.settings.ctrl_size | times: 0.45 | round }}px;
          fill: {{ block.settings.ctrl_color }};
        }
        .listicle-play-btn-{{ block.id }} .c-play  { display: none; }
        .listicle-play-btn-{{ block.id }} .c-pause { display: block; }
        .listicle-play-btn-{{ block.id }}.paused .c-play  { display: block; }
        .listicle-play-btn-{{ block.id }}.paused .c-pause { display: none; }
        .listicle-mute-btn-{{ block.id }} .c-unmuted { display: none; }
        .listicle-mute-btn-{{ block.id }} .c-muted   { display: block; }
        .listicle-mute-btn-{{ block.id }}.unmuted .c-unmuted { display: block; }
        .listicle-mute-btn-{{ block.id }}.unmuted .c-muted   { display: none; }

      {% when 'featured_collection' %}
        {%- liquid
          assign fc_bottom_overlay_style = block.settings.bottom_overlay_style
          if fc_bottom_overlay_style == blank
            if block.settings.show_bottom_overlay
              assign fc_bottom_overlay_style = 'gradient'
            else
              assign fc_bottom_overlay_style = 'none'
            endif
          endif
        -%}

        .listicle-fc-{{ block.id }} {
          background: transparent;
          padding: 0;
