{% if section.settings.enable_button_hover_effect %}
  <script>
    (function () {
      var sectionId = '{{ section.id }}';
      var hoverSelector = [
        'a[class*="listicle-hero-btn-"]',
        'button[class*="listicle-hero-btn-"]',
        'a[class*="listicle-fc-btn-"]',
        'button[class*="listicle-fc-btn-"]',
        'a[class*="listicle-fp-btn-"]',
        'button[class*="listicle-fp-btn-"]',
        'a[class*="listicle-tc-btn-"]',
        'button[class*="listicle-tc-btn-"]',
        'a[class*="listicle-if-btn-"]',
        'button[class*="listicle-if-btn-"]',
        'a[class*="listicle-iwt-btn-"]',
        'button[class*="listicle-iwt-btn-"]',
      ].join(',');

      function getPointerSide(event, element) {
        var rect = element.getBoundingClientRect();
        if (!rect.width || !rect.height) return 'left';

        var x = (event.clientX - rect.left) / rect.width - 0.5;
        var y = (event.clientY - rect.top) / rect.height - 0.5;

        if (Math.abs(x) > Math.abs(y)) {
          return x > 0 ? 'right' : 'left';
        }

        return y > 0 ? 'bottom' : 'top';
      }

      function initButtonHover(root) {
        var sectionClass = '.listicle-section-' + sectionId;
        var section = null;
        if (root && root.querySelector) {
          section = root.matches && root.matches(sectionClass) ? root : root.querySelector(sectionClass);
        } else {
          section = document.querySelector(sectionClass);
        }

        if (!section) return;

        section.querySelectorAll(hoverSelector).forEach(function (button) {
          if (button.dataset.listicleHoverReady) return;
          button.dataset.listicleHoverReady = 'true';
          button.dataset.listicleHoverSide = 'left';
          button.classList.add('listicle-directional-hover-btn');

          button.addEventListener('mouseenter', function (event) {
            if (button.disabled || button.getAttribute('aria-disabled') === 'true') return;
            button.dataset.listicleHoverSide = getPointerSide(event, button);
            button.classList.add('listicle-hover-active');
          });

          button.addEventListener('mouseleave', function (event) {
            button.dataset.listicleHoverSide = getPointerSide(event, button);
            button.classList.remove('listicle-hover-active');
          });

          button.addEventListener('focus', function () {
            if (button.disabled || button.getAttribute('aria-disabled') === 'true') return;
            button.dataset.listicleHoverSide = 'left';
            button.classList.add('listicle-hover-active');
          });

          button.addEventListener('blur', function () {
            button.classList.remove('listicle-hover-active');
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function () {
          initButtonHover(document);
        });
      } else {
        initButtonHover(document);
      }

      if (typeof Shopify !== 'undefined' && Shopify.designMode) {
        document.addEventListener('shopify:section:load', function (event) {
          initButtonHover(event.target);
        });
      }
    })();
  </script>
{% endif %}

{% if section.settings.enable_animation %}
  <script>
    (function () {
      var sectionId = '{{ section.id }}';
      function initAnimation() {
        var wrapper = document.querySelector('.listicle-blocks-wrapper-' + sectionId);
        if (!wrapper) return;
        var blocks = Array.from(wrapper.children);
        if (!('IntersectionObserver' in window)) {
          blocks.forEach(function (b) {
            b.style.opacity = '1';
          });
          return;
        }
        var delay = 0;
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting && !entry.target.classList.contains('listicle-animated')) {
                var el = entry.target;
                el.style.animationDelay = delay + 'ms';
                delay += 80;
                el.classList.add('listicle-animated');
                observer.unobserve(el);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        );
        blocks.forEach(function (b) {
          observer.observe(b);
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAnimation);
      } else {
        initAnimation();
      }
      if (typeof Shopify !== 'undefined' && Shopify.designMode) {
        document.addEventListener('shopify:section:load', initAnimation);
      }
    })();
  </script>
{% endif %}

