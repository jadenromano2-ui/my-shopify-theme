                                        {% endunless %}
                                      >
                                        <span class="listicle-global-btn-inner">
                                          {% if fc_first_variant.available %}
                                            {{ block.settings.btn_label }}
                                          {% else %}
                                            {{ 'products.product.sold_out' | t }}
                                          {% endif %}
                                        </span>
                                      </button>
                                    {% endif %}
                                  </div>
                                {% elsif block.settings.btn_label != blank %}
                                  <a href="{{ product.url }}" class="listicle-fc-btn-{{ block.id }}">
                                    {{- block.settings.btn_label -}}
                                  </a>
                                {% endif %}
                              </div>

                              {% if block.settings.show_atc
                                and block.settings.btn_label != blank
                                and product.variants.size > 1
                              %}
                                <div class="listicle-fc-overlay-{{ block.id }}">
                                  <div class="listicle-fc-overlay-header-{{ block.id }}">
                                    <p class="listicle-fc-overlay-title-{{ block.id }}">
                                      {{ block.settings.variant_title }}
                                    </p>
                                    <button
                                      type="button"
                                      class="listicle-fc-overlay-close-{{ block.id }}"
                                      aria-label="Close"
                                    >
                                      <svg
                                        width="14"
                                        height="14"
                                        viewBox="0 0 14 14"
                                        fill="none"
                                        xmlns="http://www.w3.org/2000/svg"
                                      >
                                        <path d="M1 1L13 13M1 13L13 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                      </svg>
                                    </button>
                                  </div>
                                  <div class="listicle-atc-error hidden" role="alert">
                                    <span class="listicle-atc-error__svg-wrapper">
                                      <svg class="listicle-atc-error__icon" viewBox="0 0 13 13">
                                        <circle cx="6.5" cy="6.5" r="5.5" stroke="#fff" stroke-width="2"></circle><circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width=".7"></circle><path fill="#fff" d="m5.874 3.528.1 4.044h1.053l.1-4.044zm.627 6.133c.38 0 .68-.288.68-.656s-.3-.656-.68-.656-.681.288-.681.656.3.656.68.656"></path><path fill="#fff" stroke="#EB001B" stroke-width=".7" d="M5.874 3.178h-.359l.01.359.1 4.044.008.341h1.736l.008-.341.1-4.044.01-.359H5.873Zm.627 6.833c.56 0 1.03-.432 1.03-1.006s-.47-1.006-1.03-1.006-1.031.432-1.031 1.006.47 1.006 1.03 1.006Z"></path>
                                      </svg>
                                    </span>
                                    <span class="listicle-atc-error__message"></span>
                                  </div>
                                  <select
                                    class="listicle-fc-variant-select-{{ block.id }}"
                                    aria-label="{{ 'products.product.product_variants' | t }}"
                                  >
                                    {% for variant in product.variants %}
                                      <option
                                        value="{{ variant.id }}"
                                        {% unless variant.available %}
                                          disabled
                                        {% endunless %}
                                      >
                                        {{ variant.title -}}
                                        {%- unless variant.available %}
                                          — {{ 'products.product.sold_out' | t -}}
                                        {%- endunless %}
                                      </option>
                                    {% endfor %}
                                  </select>
                                  <button
                                    type="button"
                                    class="listicle-fc-btn-{{ block.id }} listicle-atc-btn-confirm"
                                    data-variant-id="{{ fc_first_variant.id }}"
                                    data-sold-out-label="{{ 'products.product.sold_out' | t }}"
                                    data-added-label="{{ block.settings.atc_added_label }}"
                                    data-cart-app="{{ block.settings.cart_app }}"
                                    {% unless fc_first_variant.available %}
                                      disabled
                                    {% endunless %}
                                  >
                                    <span class="listicle-global-btn-inner">
                                      {%- if fc_first_variant.available -%}
                                        {{- block.settings.btn_label -}}
                                      {%- else -%}
                                        {{- 'products.product.sold_out' | t -}}
                                      {%- endif -%}
                                    </span>
                                  </button>
                                </div>
                              {% endif %}
                            </div>
                          </div>
                        </div>
                      {% endfor %}
                    {% else %}
                      {% for i in (1..block.settings.products_count) %}
                        <div class="swiper-slide">
                          <div class="listicle-fc-card-{{ block.id }}">
                            <div class="listicle-fc-img-layer-{{ block.id }} listicle-fc-first-img-{{ block.id }}">
                              {{ 'image' | placeholder_svg_tag }}
                            </div>
                            <div class="listicle-fc-content-{{ block.id }}">
                              <div class="listicle-fc-top-{{ block.id }}">
                                {% if block.settings.card_label_custom != blank %}
                                  <p class="listicle-fc-heading-{{ block.id }}">
                                    {{ block.settings.card_label_custom }}
                                  </p>
                                {% else %}
                                  <p class="listicle-fc-heading-{{ block.id }}">Collection</p>
                                {% endif %}
                              </div>
                              <div class="listicle-fc-bottom-{{ block.id }}">
                                <div class="listicle-fc-bottom-inner-{{ block.id }}">
                                  <div class="listicle-fc-title-row-{{ block.id }}">
                                    <p class="listicle-fc-product-title-{{ block.id }}">Product title</p>
                                    <p class="listicle-fc-price-{{ block.id }}">$0.00</p>
                                  </div>
                                </div>
                                {% if block.settings.show_atc and block.settings.btn_label != blank %}
                                  <div class="listicle-fc-variant-wrap-{{ block.id }}" data-product-id="123456789">
                                    <button type="button" class="listicle-fc-btn-{{ block.id }} listicle-atc-trigger">
                                      <span class="listicle-global-btn-inner">{{ block.settings.btn_label }}</span>
                                    </button>
                                  </div>
                                  <div class="listicle-fc-overlay-{{ block.id }}">
                                    <div class="listicle-fc-overlay-header-{{ block.id }}">
                                      <p class="listicle-fc-overlay-title-{{ block.id }}">
                                        {{ block.settings.variant_title }}
                                      </p>
                                      <button
                                        type="button"
                                        class="listicle-fc-overlay-close-{{ block.id }}"
                                        aria-label="Close"
                                      >
                                        <svg
                                          width="14"
                                          height="14"
                                          viewBox="0 0 14 14"
                                          fill="none"
                                          xmlns="http://www.w3.org/2000/svg"
                                        >
                                          <path d="M1 1L13 13M1 13L13 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                        </svg>
                                      </button>
                                    </div>
                                    <select class="listicle-fc-variant-select-{{ block.id }}">
                                      <option>Option 1</option>
                                      <option>Option 2</option>
                                    </select>
                                    <button
                                      type="button"
                                      class="listicle-fc-btn-{{ block.id }} listicle-atc-btn-confirm"
                                    >
                                      <span class="listicle-global-btn-inner">{{ block.settings.btn_label }}</span>
                                    </button>
                                  </div>
                                {% elsif block.settings.btn_label != blank %}
                                  <a href="#" class="listicle-fc-btn-{{ block.id }}">{{ block.settings.btn_label }}</a>
                                {% endif %}
                              </div>
                            </div>
                          </div>
                        </div>
                      {% endfor %}
                    {% endif %}
                  </div>
                </div>
                <div class="listicle-fc-dots-{{ block.id }} swiper-pagination"></div>
                <button class="listicle-fc-prev-{{ block.id }}" type="button" aria-label="Previous">
                  <span class="animate-icon"></span>
                </button>
                <button class="listicle-fc-next-{{ block.id }}" type="button" aria-label="Next">
                  <span class="animate-icon"></span>
                </button>
              </div>
            </div>
          </div>

          <script>
            function initLst3FC_{{ block_uid }}() {
              var wrapper = document.querySelector('.listicle-fc-slider-{{ block.id }}');
              if (!wrapper || wrapper.dataset.lst3Init) return;
              wrapper.dataset.lst3Init = '1';
              new Swiper('.listicle-fc-slider-{{ block.id }}', {
                slidesPerView: 1.2,
                spaceBetween: {{ block.settings.content_gap_mobile }},
                watchOverflow: true,
                navigation: {
                  prevEl: '.listicle-fc-prev-{{ block.id }}',
                  nextEl: '.listicle-fc-next-{{ block.id }}'
                },
                pagination: {
                  el: '.listicle-fc-dots-{{ block.id }}',
                  clickable: true
                },
                breakpoints: {
                  1024: {
                    slidesPerView: {{ block.settings.columns }},
                    spaceBetween: {{ block.settings.content_gap }}
                  }
                }
              });

              {% if block.settings.show_atc %}
              document.querySelectorAll('.listicle-fc-card-{{ block.id }}').forEach(function(card) {
                var select = card.querySelector('.listicle-fc-variant-select-{{ block.id }}');
                var triggerBtn = card.querySelector('.listicle-atc-trigger');
                var confirmBtn = card.querySelector('.listicle-atc-btn-confirm');
                var closeBtn = card.querySelector('.listicle-fc-overlay-close-{{ block.id }}');
                var overlay = card.querySelector('.listicle-fc-overlay-{{ block.id }}');

                if (select && select.tagName === 'SELECT') {
                  select.addEventListener('change', function() {
                    if (confirmBtn) confirmBtn.dataset.variantId = select.value;
                    var opt = select.options[select.selectedIndex];
                    if (confirmBtn) confirmBtn.disabled = opt ? !!opt.disabled : false;
                    var inner = confirmBtn ? confirmBtn.querySelector('.listicle-global-btn-inner') : null;
                    if (inner) {
                      inner.textContent = (opt && opt.disabled) ? {{ 'products.product.sold_out' | t | json }} : {{ block.settings.btn_label | json }};
                    } else if (confirmBtn) {
                      confirmBtn.textContent = (opt && opt.disabled) ? {{ 'products.product.sold_out' | t | json }} : {{ block.settings.btn_label | json }};
                    }
                  });
                  select.addEventListener('click', function(e) { e.stopPropagation(); });
                }

                if (triggerBtn && overlay) {
                  triggerBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    e.preventDefault();
                    if (triggerBtn.disabled) return;

                    document.querySelectorAll('.listicle-fc-card-{{ block.id }}.has-overlay-open').forEach(function(openCard) {
                      if (openCard !== card) {
                        openCard.classList.remove('has-overlay-open');
                        var openOverlay = openCard.querySelector('.listicle-fc-overlay-{{ block.id }}');
                        if (openOverlay) openOverlay.classList.remove('show');
                      }
                    });

                    overlay.classList.add('show');
                    card.classList.add('has-overlay-open');
                  });
                }

                if (closeBtn && overlay) {
                  closeBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    e.preventDefault();
                    overlay.classList.remove('show');
                    card.classList.remove('has-overlay-open');
                  });
                }

                if (confirmBtn && !confirmBtn.dataset.atcInit) {
                  confirmBtn.dataset.atcInit = 'true';
                  confirmBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    e.preventDefault();

                    var variantId = confirmBtn.dataset.variantId;
                    if (!variantId || confirmBtn.disabled) return;

                    var inner = confirmBtn.querySelector('.listicle-global-btn-inner') || confirmBtn;
                    var originalHTML = inner.innerHTML;
                    var addedLabel = confirmBtn.getAttribute('data-added-label') || '✓';
                    var cartApp = confirmBtn.getAttribute('data-cart-app') || 'auto-detect';

                    confirmBtn.disabled = true;
                    inner.textContent = '...';

                    var wrap = card.querySelector('.listicle-fc-variant-wrap-{{ block.id }}');
                    var productId = wrap ? wrap.dataset.productId : '';

                    var _cartEl = document.querySelector('cart-drawer, cart-notification');
                    var _sections;
                    if (_cartEl && typeof _cartEl.getSectionsToRender === 'function') {
                      _sections = _cartEl.getSectionsToRender().map(function(s) { return s.id; });
                    } else {
                      _sections = ['cart-notification', 'cart-drawer', 'cart-icon-bubble'];
                    }
                    const cartItemsComponents = document.querySelectorAll('cart-items-component');
                    cartItemsComponents.forEach((item) => {
                      if (item instanceof HTMLElement && item.dataset.sectionId) {
                        _sections.push(item.dataset.sectionId);
                      }
                    });

                    fetch('/cart/add.js', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                      body: JSON.stringify({ items: [{ id: parseInt(variantId, 10), quantity: 1 }], sections: _sections })
                    })
                    .then(function(res) { return res.json(); })
                    .then(function(data) {
                      if (data.status) {
                        inner.innerHTML = originalHTML;
                        confirmBtn.disabled = false;
                        if (data.description) {
                          var errorEl = card.querySelector('.listicle-atc-error');
                          if (errorEl) {
                            var errorMsgEl = errorEl.querySelector('.listicle-atc-error__message');
                            if (errorMsgEl) errorMsgEl.innerHTML = data.description;
                            errorEl.classList.remove('hidden');
                            setTimeout(function() {
                              errorEl.classList.add('hidden');
                            }, 4000);
                          }
                        }
                        return;
                      }
                      inner.textContent = addedLabel;

                      var themeSchemaName = (window.Shopify?.theme?.schema_name ?? '').toLowerCase();
                      const isCartApp = (name) => (cartApp === name || cartApp === "auto-detect");

                      if (isCartApp("upcart") && window.upcartOpenCart) { window.upcartOpenCart(); window.upcartRefreshCart(); return; }
                      if (isCartApp("amp-cart") && window.SLIDECART_OPEN) { window.SLIDECART_UPDATE?.(); window.SLIDECART_OPEN(); return; }
                      if (isCartApp("kaching-cart") && window.kachingCartApi) { window.kachingCartApi.openCart({refetchCart: true}); return; }

                      var cartEl = document.querySelector('cart-drawer, cart-notification');
                      if (cartEl && !['prestige', 'symmetry'].includes(themeSchemaName)) {
                        if (typeof cartEl.renderContents === 'function') {
                          const items = data.items || [];
                          items.forEach(item => {
                            item.sections = data.sections;
                            cartEl.renderContents(item);
                          });
                          cartEl.classList.remove('is-empty');
                        } else {
                          if (data.sections) {
                            var _parser = new DOMParser();
                            Object.keys(data.sections).forEach(function(id) {
                              var _src = _parser.parseFromString(data.sections[id], 'text/html').getElementById(id);
                              var _dest = document.getElementById(id);
                              if (_src && _dest) _dest.innerHTML = _src.innerHTML;
                            });
                          }
                        }
                        if (typeof cartEl.open === 'function') cartEl.open();
                        else if (typeof cartEl.show === 'function') cartEl.show();
                        return;
                      }

                      if (document.querySelector("cart-drawer-component")) {
                        const cartUpdateEvent = new Event('cart:update', {bubbles: true});
                        cartUpdateEvent.detail = {
                          data: {
                            itemCount: 1,
                            productId: parseInt(productId, 10),
                            source: "product-form-component"
                          }
                        };
                        document.dispatchEvent(cartUpdateEvent);
                        setTimeout(function() {
                          const cartDrawerComponent = document.querySelector("cart-drawer-component");
                          if (cartDrawerComponent) {
                            cartDrawerComponent.open();
                          }
                        }, 100);
                        return;
                      }

                      if (themeSchemaName === 'impulse') {
                        if (window.theme?.settings?.cartType !== "page") {
                          document.dispatchEvent(new CustomEvent('ajaxProduct:added'));
                          return;
                        }
                      }

                      if (themeSchemaName === 'prestige') {
                        if (window.themeVariables?.settings?.cartType !== "page") {
                          document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
                          const cartDrawer = document.querySelector("cart-drawer");
                          if (cartDrawer) {
                            cartDrawer.show();
                          } else {
                            document.dispatchEvent(new CustomEvent('product:added', { detail: {} }));
                          }
                          return;
                        }
                      }

                      if (themeSchemaName === 'symmetry') {
                        const afterAddToCart = window.theme?.settings?.afterAddToCart ?? window.theme?.settings?.after_add_to_cart;
                        if (afterAddToCart === "drawer") {
                          document.dispatchEvent(new CustomEvent('theme:cartchanged', { bubbles: true, cancelable: false, detail: { openDrawer: true } }));
                          document.dispatchEvent(new CustomEvent('on:cart:change'));
                          document.dispatchEvent(new CustomEvent('dispatch:cart-drawer:refresh'));
                          document.dispatchEvent(new CustomEvent('dispatch:cart-drawer:open'));
                          return;
                        } else if (afterAddToCart === "notification") {
                          document.documentElement.dispatchEvent(new CustomEvent('theme:cartchanged', { bubbles: true, cancelable: false }));
                          const items = data.items || [];
                          items.forEach(item => {
                            const template = document.getElementById('AddedNotification');
                            if (template) {
                              const notification = template.content.firstElementChild.cloneNode(true);
                              notification.dataset.productTitle = item.product_title;
                              let notificationContainer = document.querySelector('.pageheader--sticky');
                              if (!notificationContainer) {
                                notificationContainer = document.querySelector('body');
                              }
                              notificationContainer.appendChild(notification);
                            }
                          });
                          return;
                        }
                      }

                      window.location.href = window.theme?.routes?.cartPage ?? '/cart';
                    })
                    .catch(function() {
                      inner.innerHTML = originalHTML;
                      confirmBtn.disabled = false;
                    })
                    .finally(function() {
                      setTimeout(function() {
                        inner.innerHTML = originalHTML;
                        confirmBtn.disabled = false;
                      }, 2500);
                    });
                  });
                }
              });
              {% endif %}
            }
            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', initLst3FC_{{ block_uid }});
            } else { initLst3FC_{{ block_uid }}(); }
            if (typeof Shopify !== 'undefined' && Shopify.designMode) {
              document.addEventListener('shopify:section:load', initLst3FC_{{ block_uid }});
              document.addEventListener('shopify:block:select', function(e) {
                if (e.detail && e.detail.blockId === '{{ block.id }}') initLst3FC_{{ block_uid }}();
              });
            }
          </script>

        {% when 'featured_products' %}
          {%- assign fp_list = block.settings.product_list -%}
          {%- assign block_uid = block.id | replace: '-', '_' -%}
          {%- if fp_list != blank and fp_list.count > 0 -%}
            {%- assign fp_show_count = fp_list.count -%}
          {%- else -%}
            {%- assign fp_show_count = 6 -%}
          {%- endif -%}

          <div class="listicle-fp-{{ block.id }}">
            <div class="listicle-fp-inner-{{ block.id }}">
              <div class="listicle-fp-body-{{ block.id }}">
                <div class="listicle-fp-img-wrap-{{ block.id }}">
                  <div class="listicle-fp-img-swiper-{{ block.id }} swiper">
                    <div class="swiper-wrapper">
                      {% if fp_list != blank %}
                        {% for product in fp_list %}
                          <div class="swiper-slide listicle-fp-img-slide-{{ block.id }}">
                            {%- assign fp_large_image = product.images[1] | default: product.featured_image -%}
                            {% if fp_large_image != blank %}
                              {%- capture fp_sizes -%}(min-width: 1024px) {{ block.settings.img_width }}vw, 100vw{%- endcapture -%}
                              {{
                                fp_large_image
                                | image_url: width: 1200
                                | image_tag: widths: '600, 900, 1200', sizes: fp_sizes, alt: fp_large_image.alt
                              }}
                            {% else %}
                              {{ 'image' | placeholder_svg_tag }}
                            {% endif %}
                          </div>
                        {% endfor %}
                      {% else %}
                        {% for i in (1..6) %}
                          <div class="swiper-slide listicle-fp-img-slide-{{ block.id }}">
                            {{ 'image' | placeholder_svg_tag }}
                          </div>
                        {% endfor %}
                      {% endif %}
                    </div>
                  </div>
                  <div class="listicle-fp-dots-{{ block.id }} swiper-pagination"></div>
                </div>

                <div class="listicle-fp-prod-wrap-{{ block.id }}">
                  <div class="listicle-fp-prod-swiper-{{ block.id }} swiper">
                    <div class="swiper-wrapper">
                      {% if fp_list != blank %}
                        {% for product in fp_list %}
                          <div class="swiper-slide listicle-fp-prod-slide-{{ block.id }}">
                            <div class="listicle-fp-prod-body-{{ block.id }}">
                              <a href="{{ product.url }}" class="listicle-fp-small-img-{{ block.id }}">
                                {% if product.featured_image != blank %}
                                  {{
                                    product.featured_image
                                    | image_url: width: 800
                                    | image_tag:
                                      alt: product.featured_image.alt,
                                      widths: '200, 300, 400, 600, 800',
                                      sizes: '(min-width: 1024px) 400px, 50vw'
                                  }}
                                {% else %}
                                  {{ 'image' | placeholder_svg_tag }}
                                {% endif %}
                              </a>
                              <p class="listicle-fp-title-{{ block.id }}">{{ product.title }}</p>
                              {%- assign tagline = product.metafields.custom.tagline.value
                                | default: product.metafields.custom.tagline
                              -%}
                              {% if block.settings.show_text and tagline != blank %}
                                <div class="listicle-fp-text-{{ block.id }}">
                                  {{ tagline }}
                                </div>
                              {% endif %}
                              {% if block.settings.btn_label != blank %}
                                <a href="{{ product.url }}" class="listicle-fp-btn-{{ block.id }}">
                                  {{- block.settings.btn_label -}}
                                </a>
                              {% endif %}
                            </div>
                          </div>
                        {% endfor %}
                      {% else %}
                        {% for i in (1..6) %}
                          <div class="swiper-slide listicle-fp-prod-slide-{{ block.id }}">
                            <div class="listicle-fp-prod-body-{{ block.id }}">
                              <div class="listicle-fp-small-img-{{ block.id }}">
                                {{ 'image' | placeholder_svg_tag }}
                              </div>
                              <p class="listicle-fp-title-{{ block.id }}">Product title</p>
                              {% if block.settings.btn_label != blank %}
                                <a href="#" class="listicle-fp-btn-{{ block.id }}">{{ block.settings.btn_label }}</a>
                              {% endif %}
                            </div>
                          </div>
                        {% endfor %}
                      {% endif %}
                    </div>
                  </div>
                  <div class="listicle-fp-counter-{{ block.id }}">1/{{ fp_show_count }}</div>
                  <button class="listicle-fp-prev-{{ block.id }}" type="button" aria-label="Previous">
                    <span class="animate-icon"></span>
                  </button>
