{% liquid
  assign bg = section.settings.background_color
  assign fg = section.settings.foreground_color
%}

<div
  class="section section--full-width photo-spotlight spacing-style"
  style="{% render 'spacing-style', settings: section.settings %} --ps-bg: {{ bg }}; --ps-fg: {{ fg }};"
  data-testid="photo-spotlight"
>
  <div class="photo-spotlight__grid{% if section.settings.image_position == 'right' %} photo-spotlight__grid--reverse{% endif %}">
    <div class="photo-spotlight__media">
      <div class="photo-spotlight__frame">
        {% if section.settings.image_url != blank %}
          <img
            class="photo-spotlight__img"
            src="{{ section.settings.image_url }}"
            alt="{{ section.settings.image_alt | escape }}"
            loading="lazy"
            width="1200"
            height="1200"
          >
        {% endif %}
      </div>
    </div>

    <div class="photo-spotlight__text">
      {% if section.settings.eyebrow != blank %}
        <p class="photo-spotlight__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="photo-spotlight__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.body_text != blank %}
        <p class="photo-spotlight__body">{{ section.settings.body_text }}</p>
      {% endif %}
      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_link | default: 'shopify://products/item-4' }}" class="photo-spotlight__cta-link">
          {{ section.settings.cta_label }}
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2"/></svg>
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% javascript %}
  (function () {
    if (window.__psRevealInit) return;
    window.__psRevealInit = true;

    const reduceMotion =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const targets = document.querySelectorAll('.photo-spotlight__media, .photo-spotlight__text');

    if (!targets.length) return;

    if (reduceMotion || !('IntersectionObserver' in window)) {
      targets.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
    );

    targets.forEach((el) => io.observe(el));
  })();
{% endjavascript %}

{% stylesheet %}
  .photo-spotlight {
    background: var(--ps-bg, #FFFFFF);
    color: var(--ps-fg, #2E2C29);
  }

  .photo-spotlight__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(28px, 4vw, 48px);
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 64px);

    @media screen and (min-width: 900px) {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }

  .photo-spotlight__grid--reverse {
    @media screen and (min-width: 900px) {
      & .photo-spotlight__media {
        order: 2;
      }

      & .photo-spotlight__text {
        order: 1;
      }
    }
  }

  .photo-spotlight__media {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.9s var(--animation-timing-fade-in, ease), transform 0.9s var(--animation-timing-fade-in, ease);
  }

  .photo-spotlight__media.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .photo-spotlight__frame {
    position: relative;
    aspect-ratio: 1 / 1;
    border: 1px solid rgba(46, 44, 41, 0.5);
    padding: 14px;
  }

  .photo-spotlight__frame::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid rgba(46, 44, 41, 0.16);
    pointer-events: none;
    z-index: 1;
  }

  .photo-spotlight__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-spotlight__text {
    padding: clamp(8px, 1.5vw, 16px) 0;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.9s var(--animation-timing-fade-in, ease) 0.1s, transform 0.9s var(--animation-timing-fade-in, ease) 0.1s;
  }

  .photo-spotlight__text.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .photo-spotlight__eyebrow {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #2F5D62;
    margin: 0 0 14px;
  }

  .photo-spotlight__heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(2rem, 3.5vw, 2.9rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 16px;
    max-width: 16ch;
  }

  .photo-spotlight__body {
    font-family: var(--font-body--family);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: #706C63;
    margin: 0 0 24px;
    max-width: 40ch;
  }

  .photo-spotlight__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2E2C29;
    text-decoration: none;
    padding-bottom: 5px;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.25s ease, gap 0.25s ease;
  }

  .photo-spotlight__cta-link:hover {
    opacity: 0.6;
    gap: 13px;
  }

  .photo-spotlight__cta-link svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Photo spotlight",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "image_url",
      "label": "Image URL",
      "info": "Paste a Shopify CDN file URL (from Settings > Files, or a product image URL)."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "The HAUSTAS Pure One water filtration system"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Flagship"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The HAUSTAS Pure One."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "Our most complete system — full 4-stage filtration housed in a single hand-finished stainless body, built to sit quietly on the counter for decades."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "foreground_color",
      "label": "Text color",
      "default": "#2E2C29"
    },
    {
      "type": "header",
      "content": "Collection link"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link label",
      "default": "Shop The Pure One"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Photo spotlight"
    }
  ]
}
{% endschema %}
