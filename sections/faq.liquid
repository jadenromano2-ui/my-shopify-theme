{% liquid
  assign bg = section.settings.background_color
  assign fg = section.settings.foreground_color
%}

<div
  class="section section--full-width faq spacing-style"
  style="{% render 'spacing-style', settings: section.settings %} --faq-bg: {{ bg }}; --faq-fg: {{ fg }};"
  data-testid="faq"
>
  <div class="faq__intro">
    {% if section.settings.eyebrow != blank %}
      <p class="faq__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="faq__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.intro_text != blank %}
      <p class="faq__intro-text">{{ section.settings.intro_text }}</p>
    {% endif %}
  </div>

  <div class="faq__list">
    {% for block in section.blocks %}
      {% if block.type == 'question' %}
        <details class="faq__item" {{ block.shopify_attributes }}>
          <summary class="faq__question">
            <span>{{ block.settings.question }}</span>
            <span class="faq__toggle" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 8h12" stroke="currentColor" stroke-width="1.2"/>
                <path class="faq__toggle-vert" d="M8 2v12" stroke="currentColor" stroke-width="1.2"/>
              </svg>
            </span>
          </summary>
          <div class="faq__answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </details>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.cta_label != blank %}
    <div class="faq__cta">
      <a href="{{ section.settings.cta_link | default: 'shopify://collections/all' }}" class="faq__cta-link">
        {{ section.settings.cta_label }}
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2"/></svg>
      </a>
    </div>
  {% endif %}
</div>

{% javascript %}
  (function () {
    if (window.__faqRevealInit) return;
    window.__faqRevealInit = true;

    const reduceMotion =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const targets = document.querySelectorAll('.faq__intro, .faq__item');

    if (!targets.length) return;

    if (reduceMotion || !('IntersectionObserver' in window)) {
      targets.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
    );

    targets.forEach((el) => io.observe(el));
  })();
{% endjavascript %}

{% stylesheet %}
  .faq {
    background: var(--faq-bg, #F7F5F0);
    color: var(--faq-fg, #2E2C29);
  }

  .faq__intro {
    max-width: 46rem;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
    padding-bottom: clamp(28px, 3.5vw, 44px);
    text-align: center;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.8s var(--animation-timing-fade-in, ease), transform 0.8s var(--animation-timing-fade-in, ease);
  }

  .faq__intro.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .faq__eyebrow {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #706C63;
    margin: 0 0 14px;
  }

  .faq__heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(2.1rem, 4vw, 3.15rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0 0 14px;
  }

  .faq__intro-text {
    font-family: var(--font-body--family);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: #706C63;
    margin: 0 auto;
    max-width: 34rem;
  }

  .faq__list {
    max-width: 780px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 64px);
    border-top: 1px solid rgba(46, 44, 41, 0.16);
  }

  .faq__item {
    border-bottom: 1px solid rgba(46, 44, 41, 0.16);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s var(--animation-timing-fade-in, ease), transform 0.6s var(--animation-timing-fade-in, ease);
  }

  .faq__item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 22px 2px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: 1.0625rem;
    line-height: 1.35;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__toggle {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    color: #706C63;
  }

  .faq__toggle svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .faq__toggle-vert {
    transform-origin: center;
    transition: transform 0.25s ease;
  }

  .faq__item[open] .faq__toggle-vert {
    transform: scaleY(0);
  }

  .faq__answer {
    padding: 0 2px 22px;
  }

  .faq__answer p {
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
    line-height: 1.65;
    color: #706C63;
    margin: 0;
    max-width: 60ch;
  }

  .faq__cta {
    text-align: center;
    padding-top: clamp(36px, 4.5vw, 56px);
  }

  .faq__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2E2C29;
    text-decoration: none;
    padding-bottom: 5px;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.25s ease, gap 0.25s ease;
  }

  .faq__cta-link:hover {
    opacity: 0.6;
    gap: 13px;
  }

  .faq__cta-link svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Questions"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Before You Buy."
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro text",
      "default": "Everything you need to know, in one place."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#F7F5F0"
    },
    {
      "type": "color",
      "id": "foreground_color",
      "label": "Text color",
      "default": "#2E2C29"
    },
    {
      "type": "header",
      "content": "Collection link"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link label",
      "default": "View The Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How often do I need to replace the filter cartridge?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Every 6 months under normal household use. Each cartridge is engineered for a full 6-month service life before performance begins to taper."
        }
      ]
    }
  ],
