{% liquid
  assign bg = section.settings.background_color
  assign fg = section.settings.foreground_color
%}

<div
  class="section section--full-width comparison-table spacing-style"
  style="{% render 'spacing-style', settings: section.settings %} --ct-bg: {{ bg }}; --ct-fg: {{ fg }};"
  data-testid="comparison-table"
>
  <div class="comparison-table__header">
    {% if section.settings.eyebrow != blank %}
      <p class="comparison-table__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="comparison-table__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.intro_text != blank %}
      <p class="comparison-table__intro">{{ section.settings.intro_text }}</p>
    {% endif %}
  </div>

  <div class="comparison-table__grid" role="table">
    <div class="comparison-table__row comparison-table__row--head" role="row">
      <div class="comparison-table__cell comparison-table__cell--label" role="columnheader"></div>
      <div class="comparison-table__cell comparison-table__cell--haustas" role="columnheader">HAUSTAS</div>
      <div class="comparison-table__cell comparison-table__cell--typical" role="columnheader">Typical Pitcher Filter</div>
    </div>
    {% for block in section.blocks %}
      {% if block.type == 'row' %}
        <div class="comparison-table__row" role="row" {{ block.shopify_attributes }}>
          <div class="comparison-table__cell comparison-table__cell--label" role="cell">{{ block.settings.label }}</div>
          <div class="comparison-table__cell comparison-table__cell--haustas" role="cell" data-label="HAUSTAS">{{ block.settings.haustas_value }}</div>
          <div class="comparison-table__cell comparison-table__cell--typical" role="cell" data-label="Typical">{{ block.settings.typical_value }}</div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.cta_label != blank %}
    <div class="comparison-table__cta-row">
      <a href="{{ section.settings.cta_link | default: 'shopify://collections/all' }}" class="comparison-table__cta-link">
        {{ section.settings.cta_label }}
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2"/></svg>
      </a>
    </div>
  {% endif %}
</div>

{% javascript %}
  (function () {
    if (window.__ctRevealInit) return;
    window.__ctRevealInit = true;

    const reduceMotion =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const target = document.querySelector('.comparison-table__grid');

    if (!target) return;

    if (reduceMotion || !('IntersectionObserver' in window)) {
      target.classList.add('is-visible');
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -8% 0px' }
    );

    io.observe(target);
  })();
{% endjavascript %}

{% stylesheet %}
  .comparison-table {
    background: var(--ct-bg, #F7F5F0);
    color: var(--ct-fg, #2E2C29);
  }

  .comparison-table__header {
    max-width: 640px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 64px);
    text-align: center;
  }

  .comparison-table__eyebrow {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #706C63;
    margin: 0 0 14px;
  }

  .comparison-table__heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 14px;
  }

  .comparison-table__intro {
    font-family: var(--font-body--family);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: #706C63;
    margin: 0;
  }

  .comparison-table__grid {
    max-width: 900px;
    margin: clamp(36px, 5vw, 56px) auto 0;
    padding-inline: clamp(20px, 5vw, 64px);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.8s var(--animation-timing-fade-in, ease), transform 0.8s var(--animation-timing-fade-in, ease);
  }

  .comparison-table__grid.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .comparison-table__row {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr;
    border-bottom: 1px solid #D9D2C4;
  }

  .comparison-table__row--head {
    border-bottom: 1px solid #2E2C29;
  }

  .comparison-table__cell {
    padding: 16px 14px;
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
    line-height: 1.4;
  }

  .comparison-table__row--head .comparison-table__cell {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-bottom: 12px;
  }

  .comparison-table__cell--label {
    color: #2E2C29;
    font-weight: 500;
    padding-left: 0;
  }

  .comparison-table__cell--haustas {
    color: #2E2C29;
    background: rgba(46, 44, 41, 0.045);
    border-left: 2px solid #2E2C29;
    font-weight: 500;
  }

  .comparison-table__cell--typical {
    color: #9A968C;
  }

  .comparison-table__cta-row {
    text-align: center;
    margin-top: clamp(32px, 4vw, 44px);
  }

  .comparison-table__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2E2C29;
    text-decoration: none;
    padding-bottom: 5px;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.25s ease, gap 0.25s ease;
  }

  .comparison-table__cta-link:hover {
    opacity: 0.6;
    gap: 13px;
  }

  .comparison-table__cta-link svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 640px) {
    .comparison-table__row--head {
      display: none;
    }

    .comparison-table__row {
      grid-template-columns: 1fr;
      padding: 16px 0;
      border-bottom: 1px solid #D9D2C4;
    }

    .comparison-table__cell--label {
      font-family: var(--font-accent--family);
      font-weight: var(--font-accent--weight);
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #706C63;
      padding: 0 0 8px;
    }

    .comparison-table__cell--haustas,
    .comparison-table__cell--typical {
      border-left: none;
      background: none;
      padding: 6px 0 6px 14px;
      position: relative;
    }

    .comparison-table__cell--haustas {
      border-left: 2px solid #2E2C29;
    }

    .comparison-table__cell--typical {
      border-left: 2px solid #D9D2C4;
    }

    .comparison-table__cell--haustas::before,
    .comparison-table__cell--typical::before {
      content: attr(data-label);
      display: block;
      font-family: var(--font-accent--family);
      font-size: 0.625rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #9A968C;
      margin-bottom: 2px;
    }
  }
{% endstylesheet %}

{% schema %}
{
