{% liquid
  assign bg = section.settings.background_color
  assign fg = section.settings.foreground_color
%}

<div
  class="section section--full-width subscribe-save spacing-style"
  style="{% render 'spacing-style', settings: section.settings %} --ss-bg: {{ bg }}; --ss-fg: {{ fg }};"
  data-testid="subscribe-save"
>
  <div class="subscribe-save__grid">
    <div class="subscribe-save__media">
      <div class="subscribe-save__frame">
        {% if section.settings.image_url != blank %}
          <img
            class="subscribe-save__img"
            src="{{ section.settings.image_url }}"
            alt="{{ section.settings.image_alt | escape }}"
            loading="lazy"
            width="1000"
            height="1000"
          >
        {% endif %}
        {% if section.settings.badge_text != blank %}
          <span class="subscribe-save__badge">{{ section.settings.badge_text }}</span>
        {% endif %}
      </div>
    </div>

    <div class="subscribe-save__text">
      {% if section.settings.eyebrow != blank %}
        <p class="subscribe-save__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="subscribe-save__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.body_text != blank %}
        <p class="subscribe-save__body">{{ section.settings.body_text }}</p>
      {% endif %}

      {% if section.settings.price_original != blank or section.settings.price_discounted != blank %}
        <div class="subscribe-save__price-row">
          {% if section.settings.price_original != blank %}
            <span class="subscribe-save__price-original">{{ section.settings.price_original }}</span>
          {% endif %}
          {% if section.settings.price_discounted != blank %}
            <span class="subscribe-save__price-discounted">{{ section.settings.price_discounted }}</span>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.cta_label != blank %}
        <a
          href="{{ section.settings.cta_link | default: '/discount/FLOWSAVE15?redirect=/products/item-2' }}"
          class="subscribe-save__cta"
        >
          {{ section.settings.cta_label }}
        </a>
      {% endif %}

      {% if section.settings.discount_code != blank %}
        <p class="subscribe-save__code">
          {{ section.settings.code_note | default: 'Or use code' }}
          <span class="subscribe-save__code-value">{{ section.settings.discount_code }}</span>
          {{ section.settings.code_note_suffix | default: 'at checkout.' }}
        </p>
      {% endif %}
    </div>
  </div>
</div>

{% javascript %}
  (function () {
    if (window.__ssRevealInit) return;
    window.__ssRevealInit = true;

    const reduceMotion =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const targets = document.querySelectorAll('.subscribe-save__media, .subscribe-save__text');

    if (!targets.length) return;

    if (reduceMotion || !('IntersectionObserver' in window)) {
      targets.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
    );

    targets.forEach((el) => io.observe(el));
  })();
{% endjavascript %}

{% stylesheet %}
  .subscribe-save {
    background: var(--ss-bg, #FFFFFF);
    color: var(--ss-fg, #202224);
    border-top: 1px solid rgba(15, 94, 117, 0.3);
    border-bottom: 1px solid rgba(15, 94, 117, 0.3);
  }

  .subscribe-save__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(28px, 4vw, 48px);
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 64px);

    @media screen and (min-width: 900px) {
      grid-template-columns: 0.9fr 1.1fr;
    }
  }

  .subscribe-save__media {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.9s var(--animation-timing-fade-in, ease), transform 0.9s var(--animation-timing-fade-in, ease);
  }

  .subscribe-save__media.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .subscribe-save__frame {
    position: relative;
    aspect-ratio: 1 / 1;
    max-width: 420px;
    margin: 0 auto;
    border: 1px solid rgba(46, 44, 41, 0.5);
    padding: 14px;
  }

  .subscribe-save__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .subscribe-save__badge {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 2;
    background: #0F5E75;
    color: #FFFFFF;
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 7px 12px;
  }

  .subscribe-save__text {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.9s var(--animation-timing-fade-in, ease) 0.1s, transform 0.9s var(--animation-timing-fade-in, ease) 0.1s;
  }

  .subscribe-save__text.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .subscribe-save__eyebrow {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0F5E75;
    margin: 0 0 14px;
  }

  .subscribe-save__heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(2rem, 3.5vw, 2.9rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 16px;
    max-width: 18ch;
  }

  .subscribe-save__body {
    font-family: var(--font-body--family);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: #5C6368;
    margin: 0 0 24px;
    max-width: 42ch;
  }

  .subscribe-save__price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin: 0 0 28px;
  }

  .subscribe-save__price-original {
    font-family: var(--font-body--family);
    font-size: 1rem;
    color: #8B9398;
    text-decoration: line-through;
  }

  .subscribe-save__price-discounted {
    font-family: var(--font-subheading--family);
    font-weight: 600;
    font-size: 1.375rem;
    color: #202224;
    font-variant-numeric: tabular-nums;
  }

  .subscribe-save__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 34px;
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #FFFFFF;
    background: #0F5E75;
    text-decoration: none;
    border: 1px solid #0F5E75;
    transition: background 0.25s ease, color 0.25s ease;
  }

  .subscribe-save__cta:hover {
    background: transparent;
    color: #0F5E75;
  }

  .subscribe-save__code {
    margin: 18px 0 0;
    font-family: var(--font-body--family);
    font-size: 0.8125rem;
    color: #5C6368;
  }

  .subscribe-save__code-value {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    letter-spacing: 0.08em;
    color: #202224;
    border-bottom: 1px dashed #C8D1CC;
    padding-bottom: 1px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Subscribe & save",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "image_url",
      "label": "Image URL",
      "default": "https://cdn.shopify.com/s/files/1/0730/5648/5512/files/2C9B0546-6C26-44BA-B8E9-0DE754B16C86.png?v=1782787825"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "HAUSTAS Flow replacement filter cartridge"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Save 15%"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Never Run Dry"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stock Up On Cartridges & Save 15%."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "Every HAUSTAS cartridge lasts about 6 months. Stock up now and save 15% on HAUSTAS Flow replacements — one less thing to think about later."
    },
    {
      "type": "text",
      "id": "price_original",
      "label": "Original price",
      "default": "$29.00"
    },
    {
      "type": "text",
      "id": "price_discounted",
      "label": "Discounted price",
      "default": "$24.65"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Save 15% Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link (auto-applies discount)"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount code",
      "default": "FLOWSAVE15"
    },
    {
      "type": "text",
      "id": "code_note",
      "label": "Code note (before code)",
      "default": "Or use code"
    },
    {
      "type": "text",
      "id": "code_note_suffix",
      "label": "Code note (after code)",
      "default": "at checkout."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "foreground_color",
      "label": "Text color",
      "default": "#202224"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    }
  ]
}
{% endschema %}
