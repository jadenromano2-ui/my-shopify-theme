              <text x="30" y="46" text-anchor="start" class="fd-diagram-label">60&#8211;100 PSI</text>
              <line x1="26" y1="60" x2="94" y2="60" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <path d="M86 54 L96 60 L86 66" class="fd-draw" stroke="currentColor" stroke-width="1" fill="none"/>

              <rect x="26" y="60" width="70" height="100" class="fd-draw" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2 3"/>
              <circle cx="46" cy="82" r="1.4" class="fd-fill" fill="currentColor"/>
              <circle cx="66" cy="76" r="1.4" class="fd-fill" fill="currentColor"/>
              <circle cx="54" cy="102" r="1.4" class="fd-fill" fill="currentColor"/>
              <circle cx="76" cy="98" r="1.4" class="fd-fill" fill="currentColor"/>
              <circle cx="40" cy="122" r="1.4" class="fd-fill" fill="currentColor"/>
              <circle cx="70" cy="130" r="1.4" class="fd-fill" fill="currentColor"/>
              <circle cx="52" cy="146" r="1.4" class="fd-fill" fill="currentColor"/>
              <circle cx="82" cy="118" r="1.4" class="fd-fill" fill="currentColor"/>

              <rect x="108" y="52" width="10" height="116" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <line x1="113" y1="58" x2="113" y2="162" class="fd-draw" stroke="currentColor" stroke-width="0.5" stroke-dasharray="1 2"/>
              <text x="113" y="42" text-anchor="middle" class="fd-diagram-label">SEMI-PERMEABLE</text>
