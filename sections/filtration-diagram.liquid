{% liquid
  assign bg = section.settings.background_color
  assign fg = section.settings.foreground_color
%}

<div
  class="section section--full-width filtration-diagram spacing-style"
  style="{% render 'spacing-style', settings: section.settings %} --fd-bg: {{ bg }}; --fd-fg: {{ fg }};"
  data-testid="filtration-diagram"
>
  <div class="filtration-diagram__grid{% if section.settings.image_position == 'right' %} filtration-diagram__grid--reverse{% endif %}">
    <div class="filtration-diagram__media">
      <div class="filtration-diagram__frame">
        <span class="filtration-diagram__scale-tick filtration-diagram__scale-tick--left"></span>
        <span class="filtration-diagram__scale-tick filtration-diagram__scale-tick--right"></span>

        {% case section.settings.diagram %}
          {% when 'ultrafiltration' %}
            <svg class="fd-diagram" viewBox="0 0 240 240" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <text x="120" y="20" text-anchor="middle" class="fd-diagram-label fd-diagram-label--head">FEED WATER IN</text>
              <line x1="120" y1="26" x2="120" y2="42" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <path d="M114 36 L120 44 L126 36" class="fd-draw" stroke="currentColor" stroke-width="1" fill="none"/>

              <rect x="46" y="46" width="148" height="140" rx="2" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <line x1="46" y1="46" x2="46" y2="186" class="fd-draw" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2 3"/>
              <line x1="194" y1="46" x2="194" y2="186" class="fd-draw" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2 3"/>

              <rect x="76" y="60" width="10" height="112" rx="5" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <line x1="81" y1="66" x2="81" y2="166" class="fd-draw" stroke="currentColor" stroke-width="0.5" stroke-dasharray="1 2"/>
              <rect x="105" y="60" width="10" height="112" rx="5" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <line x1="110" y1="66" x2="110" y2="166" class="fd-draw" stroke="currentColor" stroke-width="0.5" stroke-dasharray="1 2"/>
              <rect x="134" y="60" width="10" height="112" rx="5" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <line x1="139" y1="66" x2="139" y2="166" class="fd-draw" stroke="currentColor" stroke-width="0.5" stroke-dasharray="1 2"/>
              <rect x="163" y="60" width="10" height="112" rx="5" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <line x1="168" y1="66" x2="168" y2="166" class="fd-draw" stroke="currentColor" stroke-width="0.5" stroke-dasharray="1 2"/>

              <circle cx="60" cy="72" r="1.3" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.6"/>
              <circle cx="66" cy="94" r="1.3" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.6"/>
              <circle cx="58" cy="118" r="1.3" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.6"/>
              <circle cx="95" cy="80" r="1.3" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.6"/>
              <circle cx="124" cy="70" r="1.3" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.6"/>
              <circle cx="152" cy="90" r="1.3" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.6"/>
              <circle cx="180" cy="76" r="1.3" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.6"/>
              <circle cx="184" cy="120" r="1.3" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.6"/>
              <circle cx="70" cy="150" r="1.3" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.6"/>
