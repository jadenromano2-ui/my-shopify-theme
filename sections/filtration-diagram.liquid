              <path d="M150 78 L196 78 L196 106 L150 106 Z" class="fd-draw" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3"/>
              <text x="173" y="70" text-anchor="middle" class="fd-diagram-label">STORAGE TANK</text>

              <line x1="196 " y1="92" x2="220" y2="92" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <circle cx="222" cy="92" r="2" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <text x="200" y="118" text-anchor="start" class="fd-diagram-label fd-diagram-label--head">PURIFIED, ON DEMAND</text>

              <line x1="46" y1="160" x2="46" y2="196" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <path d="M40 190 L46 198 L52 190" class="fd-draw" stroke="currentColor" stroke-width="1" fill="none"/>
              <text x="46" y="212" text-anchor="middle" class="fd-diagram-label fd-diagram-label--head">CONCENTRATE</text>
              <text x="46" y="224" text-anchor="middle" class="fd-diagram-label">TO DRAIN</text>

              <text x="150" y="140" text-anchor="start" class="fd-diagram-label">DISSOLVED SOLIDS +</text>
              <text x="150" y="150" text-anchor="start" class="fd-diagram-label">HEAVY METALS REJECTED</text>
            </svg>

          {% else %}
            <svg class="fd-diagram" viewBox="0 0 240 240" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <text x="70" y="20" text-anchor="middle" class="fd-diagram-label fd-diagram-label--head">TAP WATER IN</text>
              <line x1="70" y1="26" x2="70" y2="48" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <path d="M64 42 L70 50 L76 42" class="fd-draw" stroke="currentColor" stroke-width="1" fill="none"/>

              <rect x="54" y="48" width="32" height="72" rx="4" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <line x1="54" y1="78" x2="86" y2="78" class="fd-draw" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2 3"/>
              <text x="94" y="66" text-anchor="start" class="fd-diagram-label">FAUCET BODY</text>

              <path d="M70 120 C70 156 70 156 108 156 L172 156" class="fd-draw" stroke="currentColor" stroke-width="1" fill="none"/>
              <path d="M70 128 C70 148 70 148 108 148 L150 148" class="fd-draw" stroke="currentColor" stroke-width="0.6" stroke-dasharray="1 2" fill="none"/>

              <rect x="108" y="132" width="64" height="24" rx="2" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <circle cx="118" cy="140" r="1.2" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.5"/>
              <circle cx="126" cy="148" r="1.2" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.5"/>
              <circle cx="134" cy="141" r="1.2" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.5"/>
              <circle cx="142" cy="149" r="1.2" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.5"/>
              <circle cx="150" cy="140" r="1.2" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.5"/>
              <circle cx="158" cy="148" r="1.2" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.5"/>
              <circle cx="165" cy="141" r="1.2" class="fd-draw fd-fill" stroke="currentColor" stroke-width="0.5"/>
              <text x="140" y="176" text-anchor="middle" class="fd-diagram-label">CARBON + SEDIMENT MEDIA</text>

              <path d="M108 144 L96 144 L96 160 L108 160" class="fd-draw" stroke="currentColor" stroke-width="0.6" stroke-dasharray="1 2" fill="none"/>
              <text x="60" y="192" text-anchor="start" class="fd-diagram-label">TOOL-FREE CARTRIDGE SWAP</text>
              <path d="M96 168 L96 178 L88 178" class="fd-draw" stroke="currentColor" stroke-width="0.6"/>

              <line x1="172" y1="150" x2="196" y2="150" class="fd-draw" stroke="currentColor" stroke-width="1"/>
              <path d="M190 144 L198 150 L190 156" class="fd-draw" stroke="currentColor" stroke-width="1" fill="none"/>
              <text x="200" y="146" text-anchor="start" class="fd-diagram-label fd-diagram-label--head">FILTERED WATER</text>
              <text x="200" y="158" text-anchor="start" class="fd-diagram-label fd-diagram-label--head">AT THE TAP</text>
            </svg>
        {% endcase %}
      </div>
    </div>

    <div class="filtration-diagram__text">
      {% if section.settings.eyebrow != blank %}
        <p class="filtration-diagram__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="filtration-diagram__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.body_text != blank %}
        <p class="filtration-diagram__body">{{ section.settings.body_text }}</p>
      {% endif %}

      {% if section.settings.spec_1_label != blank or section.settings.spec_2_label != blank or section.settings.spec_3_label != blank %}
        <dl class="filtration-diagram__specs">
          {% if section.settings.spec_1_label != blank %}
            <div class="filtration-diagram__spec-row">
              <dt>{{ section.settings.spec_1_label }}</dt>
              <dd>{{ section.settings.spec_1_value }}</dd>
            </div>
          {% endif %}
          {% if section.settings.spec_2_label != blank %}
            <div class="filtration-diagram__spec-row">
              <dt>{{ section.settings.spec_2_label }}</dt>
              <dd>{{ section.settings.spec_2_value }}</dd>
            </div>
          {% endif %}
          {% if section.settings.spec_3_label != blank %}
            <div class="filtration-diagram__spec-row">
              <dt>{{ section.settings.spec_3_label }}</dt>
              <dd>{{ section.settings.spec_3_value }}</dd>
            </div>
          {% endif %}
        </dl>
      {% endif %}

      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_link | default: 'shopify://collections/all' }}" class="filtration-diagram__cta-link">
          {{ section.settings.cta_label }}
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2"/></svg>
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% javascript %}
  (function () {
    if (window.__fdRevealInit) return;
    window.__fdRevealInit = true;

    const reduceMotion =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const targets = document.querySelectorAll('.filtration-diagram__media, .filtration-diagram__text');

    if (!targets.length) return;

    if (reduceMotion || !('IntersectionObserver' in window)) {
      targets.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
    );

    targets.forEach((el) => io.observe(el));
  })();
{% endjavascript %}

{% stylesheet %}
  .filtration-diagram {
    background: var(--fd-bg, #FFFFFF);
    color: var(--fd-fg, #202224);
  }

  .filtration-diagram__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(28px, 4vw, 48px);
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 64px);

    @media screen and (min-width: 900px) {
      grid-template-columns: 1fr 1fr;
    }
  }

  .filtration-diagram__grid--reverse {
    @media screen and (min-width: 900px) {
      & .filtration-diagram__media {
        order: 2;
      }

      & .filtration-diagram__text {
        order: 1;
      }
    }
  }

  .filtration-diagram__media {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(16px, 3vw, 32px);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.9s var(--animation-timing-fade-in, ease), transform 0.9s var(--animation-timing-fade-in, ease);
  }

  .filtration-diagram__media.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .filtration-diagram__frame {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid currentColor;
    opacity: 0.94;
    position: relative;
    padding: 20px;
  }

  .filtration-diagram__frame::before {
    content: '';
    position: absolute;
    inset: 8px;
    border: 1px solid currentColor;
    opacity: 0.22;
    pointer-events: none;
  }

  .filtration-diagram__frame::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(to right, #0F5E75 2px, transparent 2px),
      linear-gradient(to right, #0F5E75 2px, transparent 2px),
      linear-gradient(to left, #0F5E75 2px, transparent 2px),
      linear-gradient(to left, #0F5E75 2px, transparent 2px),
      linear-gradient(to bottom, #0F5E75 2px, transparent 2px),
      linear-gradient(to bottom, #0F5E75 2px, transparent 2px),
      linear-gradient(to top, #0F5E75 2px, transparent 2px),
      linear-gradient(to top, #0F5E75 2px, transparent 2px);
    background-position: top left, bottom left, top right, bottom right, top left, top right, bottom left, bottom right;
    background-repeat: no-repeat;
    background-size: 16px 2px, 16px 2px, 16px 2px, 16px 2px, 2px 16px, 2px 16px, 2px 16px, 2px 16px;
  }

  .filtration-diagram__scale-tick {
    position: absolute;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: currentColor;
    opacity: 0.16;
  }

  .filtration-diagram__scale-tick--left {
    left: 18%;
  }

  .filtration-diagram__scale-tick--right {
    right: 18%;
  }

  .fd-diagram {
    width: 100%;
    height: 100%;
    color: #0F5E75;
  }

  .fd-diagram-label {
    font-family: ui-monospace, 'SF Mono', 'Cascadia Code', 'Roboto Mono', Menlo, Consolas, monospace;
    font-size: 6px;
    letter-spacing: 0.03em;
    fill: currentColor;
    opacity: 0.6;
  }

  .fd-diagram-label--head {
    opacity: 0.85;
    font-weight: 600;
  }

  .fd-fill {
    fill: currentColor;
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    .fd-draw {
      stroke-dasharray: 260;
      stroke-dashoffset: 260;
      transition: stroke-dashoffset 1.4s var(--animation-timing-fade-in, ease) 0.2s;
    }

    .is-visible .fd-draw {
      stroke-dashoffset: 0;
    }
  }

  .filtration-diagram__text {
    padding: clamp(8px, 1.5vw, 16px) 0;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.9s var(--animation-timing-fade-in, ease) 0.1s, transform 0.9s var(--animation-timing-fade-in, ease) 0.1s;
  }

  .filtration-diagram__text.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .filtration-diagram__eyebrow {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0F5E75;
    margin: 0 0 14px;
  }

  .filtration-diagram__heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(2rem, 3.5vw, 2.9rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 16px;
    max-width: 16ch;
  }

  .filtration-diagram__body {
    font-family: var(--font-body--family);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: #5C6368;
    margin: 0 0 24px;
    max-width: 44ch;
  }

  .filtration-diagram__specs {
    margin: 0 0 28px;
    padding-top: 18px;
    border-top: 1px solid #C8D1CC;
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: 44ch;
  }

  .filtration-diagram__spec-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    font-family: ui-monospace, 'SF Mono', 'Cascadia Code', 'Roboto Mono', Menlo, Consolas, monospace;
    font-size: 0.8125rem;
  }

  .filtration-diagram__spec-row dt {
    color: #8B9398;
  }

  .filtration-diagram__spec-row dd {
    margin: 0;
    color: #202224;
    font-weight: 600;
    text-align: right;
  }

  .filtration-diagram__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #202224;
    text-decoration: none;
    padding-bottom: 5px;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.25s ease, gap 0.25s ease;
  }

  .filtration-diagram__cta-link:hover {
    opacity: 0.6;
    gap: 13px;
  }

  .filtration-diagram__cta-link svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Filtration diagram",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "diagram",
      "label": "Diagram",
      "options": [
        { "value": "ultrafiltration", "label": "Ultrafiltration" },
        { "value": "reverse-osmosis", "label": "Reverse Osmosis" },
        { "value": "faucet", "label": "Faucet Filtration" }
      ],
      "default": "ultrafiltration"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Diagram position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Ultrafiltration"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Membrane Filtration, Without The Waste."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text"
    },
    {
      "type": "header",
      "content": "Spec sheet"
    },
    { "type": "text", "id": "spec_1_label", "label": "Spec 1 label" },
    { "type": "text", "id": "spec_1_value", "label": "Spec 1 value" },
    { "type": "text", "id": "spec_2_label", "label": "Spec 2 label" },
    { "type": "text", "id": "spec_2_value", "label": "Spec 2 value" },
    { "type": "text", "id": "spec_3_label", "label": "Spec 3 label" },
    { "type": "text", "id": "spec_3_value", "label": "Spec 3 value" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "foreground_color",
      "label": "Text color",
