              <path d="M46 210 L96 210" class="fd-draw" stroke="currentColor" stroke-width="0.6"/>
              <text x="26" y="213" text-anchor="start" class="fd-diagram-label">4× HOLLOW-FIBER MEMBRANE</text>
              <path d="M144 210 L194 210" class="fd-draw" stroke="currentColor" stroke-width="0.6"/>
