{% javascript %}
  (function () {
    if (window.__epRevealInit) return;
    window.__epRevealInit = true;

    const reduceMotion =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const rows = document.querySelectorAll('.engineered-precision__row');

    if (!rows.length) return;

    if (reduceMotion || !('IntersectionObserver' in window)) {
      rows.forEach((row) => row.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.18, rootMargin: '0px 0px -8% 0px' }
    );

    rows.forEach((row) => io.observe(row));
  })();
{% endjavascript %}

{% stylesheet %}
  .engineered-precision {
    background: var(--ep-light-bg, #FFFFFF);
    overflow: hidden;
  }

  .engineered-precision__intro {
    max-width: 46rem;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
    padding-bottom: clamp(32px, 4vw, 52px);
    text-align: center;
  }

  .engineered-precision__eyebrow {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0F5E75;
    margin: 0 0 14px;
  }

  .engineered-precision__heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(2.1rem, 4vw, 3.15rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: #202224;
    margin: 0 0 14px;
  }

  .engineered-precision__intro-text {
    font-family: var(--font-body--family);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: #5C6368;
    margin: 0 auto;
    max-width: 34rem;
  }

  .engineered-precision__row {
    display: grid;
    grid-template-columns: 1fr;
    align-items: stretch;
    border-top: 1px solid rgba(46, 44, 41, 0.12);
    background: var(--ep-light-bg, #FFFFFF);
    color: var(--ep-light-fg, #202224);
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.9s var(--animation-timing-fade-in, ease), transform 0.9s var(--animation-timing-fade-in, ease);

    @media screen and (min-width: 900px) {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }

  .engineered-precision__row.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .engineered-precision__row--dark {
    background: var(--ep-dark-bg, #211F1C);
    color: var(--ep-dark-fg, #F2EFE9);
    border-top-color: rgba(242, 239, 233, 0.14);
  }

  @media screen and (min-width: 900px) {
    .engineered-precision__row--reverse {
      & .engineered-precision__text {
        order: 2;
      }

      & .engineered-precision__diagram {
        order: 1;
      }
    }
  }

  .engineered-precision__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(36px, 5vw, 60px) clamp(20px, 5vw, 64px);
  }

  .engineered-precision__spec {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid currentColor;
    opacity: 0.9;
    max-width: 320px;
  }

  .engineered-precision__spec-code,
  .engineered-precision__fig {
    font-family: ui-monospace, 'SF Mono', 'Cascadia Code', 'Roboto Mono', Menlo, Consolas, monospace;
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.65;
  }

  .engineered-precision__panel-heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(1.7rem, 2.3vw, 2.15rem);
    line-height: 1.12;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
    max-width: 18ch;
  }

  .engineered-precision__panel-body {
    font-family: var(--font-body--family);
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.78;
    margin: 0;
    max-width: 34ch;
  }

  .engineered-precision__datasheet {
    margin: 22px 0 0;
    padding-top: 18px;
    border-top: 1px solid currentColor;
    opacity: 0.9;
    max-width: 34ch;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .engineered-precision__datasheet-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 9px 0;
    border-bottom: 1px dashed currentColor;
    opacity: 0.85;
  }

  .engineered-precision__datasheet-row:last-child {
    border-bottom: none;
  }

  .engineered-precision__datasheet-row dt {
    font-family: ui-monospace, 'SF Mono', 'Cascadia Code', 'Roboto Mono', Menlo, Consolas, monospace;
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.55;
    margin: 0;
    white-space: nowrap;
  }

  .engineered-precision__datasheet-row dd {
    font-family: ui-monospace, 'SF Mono', 'Cascadia Code', 'Roboto Mono', Menlo, Consolas, monospace;
    font-size: 0.875rem;
    text-align: right;
    margin: 0;
    opacity: 0.92;
  }

  .engineered-precision__diagram {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(20px, 3vw, 36px);
    min-height: 240px;
  }

  .engineered-precision__diagram-frame {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 11 / 10;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid currentColor;
    opacity: 0.94;
    position: relative;
  }

  .engineered-precision__diagram-frame::before {
    content: '';
    position: absolute;
    inset: 8px;
    border: 1px solid currentColor;
    opacity: 0.28;
    pointer-events: none;
  }

  .engineered-precision__diagram-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(to right, #0F5E75 2px, transparent 2px),
      linear-gradient(to right, #0F5E75 2px, transparent 2px),
      linear-gradient(to left, #0F5E75 2px, transparent 2px),
      linear-gradient(to left, #0F5E75 2px, transparent 2px),
      linear-gradient(to bottom, #0F5E75 2px, transparent 2px),
      linear-gradient(to bottom, #0F5E75 2px, transparent 2px),
      linear-gradient(to top, #0F5E75 2px, transparent 2px),
      linear-gradient(to top, #0F5E75 2px, transparent 2px);
    background-position: top left, bottom left, top right, bottom right, top left, top right, bottom left, bottom right;
    background-repeat: no-repeat;
    background-size: 16px 2px, 16px 2px, 16px 2px, 16px 2px, 2px 16px, 2px 16px, 2px 16px, 2px 16px;
  }

  .engineered-precision__scale-tick {
    position: absolute;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: currentColor;
    opacity: 0.2;
  }

  .engineered-precision__scale-tick--left {
    left: 20%;
  }

  .engineered-precision__scale-tick--right {
    right: 20%;
  }

  .ep-diagram {
    width: 90%;
    height: 90%;
    color: currentColor;
  }

  .ep-diagram-label {
    font-family: ui-monospace, 'SF Mono', 'Cascadia Code', 'Roboto Mono', Menlo, Consolas, monospace;
    font-size: 6.25px;
    letter-spacing: 0.04em;
    fill: currentColor;
    opacity: 0.62;
  }

  .ep-diagram-label--head {
    opacity: 0.85;
    font-weight: 600;
  }

  .ep-fill {
    fill: currentColor;
  }

  .ep-fill-solid {
    fill: currentColor;
    fill-opacity: 0.06;
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    .ep-draw {
      stroke-dasharray: 240;
      stroke-dashoffset: 240;
      transition: stroke-dashoffset 1.4s var(--animation-timing-fade-in, ease) 0.2s;
    }

    .is-visible .ep-draw {
      stroke-dashoffset: 0;
    }
  }

  .engineered-precision__cta {
    text-align: center;
    padding: clamp(40px, 5vw, 64px) clamp(20px, 5vw, 64px);
    border-top: 1px solid rgba(46, 44, 41, 0.12);
  }

  .engineered-precision__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #202224;
    text-decoration: none;
    padding-bottom: 5px;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.25s ease, gap 0.25s ease;
  }

  .engineered-precision__cta-link:hover {
    opacity: 0.6;
    gap: 13px;
  }

  .engineered-precision__cta-link svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }
{% endstylesheet %}

