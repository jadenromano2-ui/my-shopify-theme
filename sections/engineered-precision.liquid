{% liquid
  assign light_bg = section.settings.light_background
  assign light_fg = section.settings.light_foreground
  assign dark_bg = section.settings.dark_background
  assign dark_fg = section.settings.dark_foreground
%}

<div
  class="section section--full-width engineered-precision spacing-style"
  style="{% render 'spacing-style', settings: section.settings %} --ep-light-bg: {{ light_bg }}; --ep-light-fg: {{ light_fg }}; --ep-dark-bg: {{ dark_bg }}; --ep-dark-fg: {{ dark_fg }};"
  data-testid="engineered-precision"
>
  <div class="engineered-precision__intro">
    {% if section.settings.eyebrow != blank %}
      <p class="engineered-precision__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="engineered-precision__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.intro_text != blank %}
      <p class="engineered-precision__intro-text">{{ section.settings.intro_text }}</p>
    {% endif %}
  </div>

  <div class="engineered-precision__rows">
    {% for block in section.blocks %}
      {% liquid
        assign is_dark = false
        if block.settings.row_theme == 'dark'
          assign is_dark = true
        endif
        assign is_reverse = false
        if forloop.index0 == 1 or forloop.index0 == 3
          assign is_reverse = true
        endif
      %}
      <div
        class="engineered-precision__row{% if is_dark %} engineered-precision__row--dark{% endif %}{% if is_reverse %} engineered-precision__row--reverse{% endif %}"
        {{ block.shopify_attributes }}
      >
        <div class="engineered-precision__text">
          <div class="engineered-precision__spec">
            {% if block.settings.spec_code != blank %}
              <span class="engineered-precision__spec-code">{{ block.settings.spec_code }}</span>
            {% endif %}
            {% if block.settings.fig_number != blank %}
              <span class="engineered-precision__fig">{{ block.settings.fig_number }}</span>
            {% endif %}
          </div>
          {% if block.settings.heading != blank %}
            <h3 class="engineered-precision__panel-heading">{{ block.settings.heading }}</h3>
          {% endif %}
          {% if block.settings.body != blank %}
            <p class="engineered-precision__panel-body">{{ block.settings.body }}</p>
          {% endif %}
          {% if block.settings.spec_line_1 != blank or block.settings.spec_line_2 != blank or block.settings.spec_line_3 != blank %}
            <dl class="engineered-precision__datasheet">
              {% if block.settings.spec_line_1 != blank %}
                {% assign l1 = block.settings.spec_line_1 | split: ' — ' %}
                <div class="engineered-precision__datasheet-row">
                  <dt>{{ l1[0] }}</dt>
                  <dd>{{ l1[1] | default: l1[0] }}</dd>
                </div>
              {% endif %}
              {% if block.settings.spec_line_2 != blank %}
                {% assign l2 = block.settings.spec_line_2 | split: ' — ' %}
                <div class="engineered-precision__datasheet-row">
                  <dt>{{ l2[0] }}</dt>
                  <dd>{{ l2[1] | default: l2[0] }}</dd>
                </div>
              {% endif %}
              {% if block.settings.spec_line_3 != blank %}
                {% assign l3 = block.settings.spec_line_3 | split: ' — ' %}
                <div class="engineered-precision__datasheet-row">
                  <dt>{{ l3[0] }}</dt>
                  <dd>{{ l3[1] | default: l3[0] }}</dd>
                </div>
              {% endif %}
            </dl>
          {% endif %}
        </div>

        <div class="engineered-precision__diagram">
          <div class="engineered-precision__diagram-frame">
            <span class="engineered-precision__scale-tick engineered-precision__scale-tick--left"></span>
            <span class="engineered-precision__scale-tick engineered-precision__scale-tick--right"></span>
            {% case block.settings.diagram %}
              {% when 'craftsmanship' %}
                <svg class="ep-diagram" viewBox="0 0 240 220" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="76" y="86" width="88" height="52" rx="1" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <line x1="76" y1="68" x2="76" y2="150" class="ep-draw" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2 3"/>
                  <line x1="164" y1="68" x2="164" y2="150" class="ep-draw" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2 3"/>
                  <line x1="76" y1="56" x2="164" y2="56" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <line x1="76" y1="52" x2="76" y2="60" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <line x1="164" y1="52" x2="164" y2="60" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <text x="120" y="46" text-anchor="middle" class="ep-diagram-label">68.00MM BORE</text>
                  <circle cx="90" cy="100" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <circle cx="150" cy="100" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <circle cx="90" cy="124" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <circle cx="150" cy="124" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <path d="M48 100 L74 100" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <path d="M48 92 L48 108" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <text x="44" y="88" text-anchor="end" class="ep-diagram-label">MOUNT (4)</text>
                  <path d="M192 112 L166 112" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <path d="M192 104 L192 120" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <text x="196" y="116" text-anchor="start" class="ep-diagram-label">MACHINED BODY</text>
                  <line x1="120" y1="138" x2="120" y2="170" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <text x="120" y="182" text-anchor="middle" class="ep-diagram-label">HAND-FITTED SEAM</text>
                </svg>
              {% when 'materials' %}
                <svg class="ep-diagram" viewBox="0 0 240 220" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <line x1="44" y1="70" x2="196" y2="70" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <rect x="44" y="86" width="44" height="44" class="ep-draw ep-fill-solid" stroke="currentColor" stroke-width="1"/>
                  <circle cx="120" cy="108" r="22" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <path d="M174 86 L196 86 L196 130 L174 130 Z" class="ep-draw" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3"/>
                  <path d="M66 130 L66 146" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <text x="66" y="158" text-anchor="middle" class="ep-diagram-label">304-SS SHELL</text>
                  <path d="M120 130 L120 146" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <text x="120" y="158" text-anchor="middle" class="ep-diagram-label">GLASS CORE</text>
                  <path d="M185 130 L185 146" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <text x="185" y="158" text-anchor="middle" class="ep-diagram-label">STEEL TRIM</text>
                  <line x1="44" y1="172" x2="196" y2="172" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <text x="120" y="188" text-anchor="middle" class="ep-diagram-label">SATIN, NON-REFLECTIVE FINISH</text>
                </svg>
              {% when 'engineering' %}
                <svg class="ep-diagram" viewBox="0 0 240 220" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <ellipse cx="120" cy="50" rx="50" ry="10" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <ellipse cx="120" cy="82" rx="42" ry="9" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <ellipse cx="120" cy="112" rx="34" ry="8" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <ellipse cx="120" cy="140" rx="24" ry="6" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <line x1="70" y1="50" x2="70" y2="140" class="ep-draw" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 3"/>
                  <line x1="170" y1="50" x2="170" y2="140" class="ep-draw" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 3"/>
                  <line x1="120" y1="18" x2="120" y2="40" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <circle cx="120" cy="14" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <text x="180" y="52" text-anchor="start" class="ep-diagram-label">01 SEDIMENT</text>
                  <text x="180" y="84" text-anchor="start" class="ep-diagram-label">02 CARBON BLOCK</text>
                  <text x="180" y="114" text-anchor="start" class="ep-diagram-label">03 KDF MEDIA</text>
                  <text x="180" y="142" text-anchor="start" class="ep-diagram-label">04 POLISH</text>
                  <line x1="120" y1="150" x2="120" y2="176" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <circle cx="120" cy="180" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <text x="120" y="198" text-anchor="middle" class="ep-diagram-label">2.5 L/MIN OUTPUT</text>
                </svg>
              {% when 'timeless' %}
                <svg class="ep-diagram" viewBox="0 0 240 220" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="120" cy="104" r="72" class="ep-draw" stroke="currentColor" stroke-width="0.6" stroke-dasharray="1 4"/>
                  <path d="M102 56 C102 50 138 50 138 56 L142 132 C142 154 98 154 98 132 Z" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <line x1="110" y1="72" x2="130" y2="72" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <path d="M162 90 L182 90" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <text x="186" y="94" text-anchor="start" class="ep-diagram-label">SOLID FORM</text>
                  <path d="M162 118 L182 118" class="ep-draw" stroke="currentColor" stroke-width="0.6"/>
                  <text x="186" y="122" text-anchor="start" class="ep-diagram-label">SILHOUETTE STUDY</text>
                  <line x1="70" y1="184" x2="170" y2="184" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <text x="70" y="200" text-anchor="start" class="ep-diagram-label">2024</text>
                  <text x="170" y="200" text-anchor="end" class="ep-diagram-label">TIMELESS</text>
                </svg>
            {% endcase %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  {% if section.settings.cta_label != blank %}
    <div class="engineered-precision__cta">
      <a href="{{ section.settings.cta_link | default: 'shopify://collections/all' }}" class="engineered-precision__cta-link">
        {{ section.settings.cta_label }}
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2"/></svg>
      </a>
    </div>
  {% endif %}
</div>

{% javascript %}
  (function () {
    if (window.__epRevealInit) return;
    window.__epRevealInit = true;

    const reduceMotion =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const rows = document.querySelectorAll('.engineered-precision__row');

    if (!rows.length) return;

    if (reduceMotion || !('IntersectionObserver' in window)) {
      rows.forEach((row) => row.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.18, rootMargin: '0px 0px -8% 0px' }
    );

    rows.forEach((row) => io.observe(row));
  })();
{% endjavascript %}

{% stylesheet %}
  .engineered-precision {
    background: var(--ep-light-bg, #FFFFFF);
    overflow: hidden;
  }

  .engineered-precision__intro {
    max-width: 46rem;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
    padding-bottom: clamp(32px, 4vw, 52px);
    text-align: center;
  }

  .engineered-precision__eyebrow {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #706C63;
    margin: 0 0 14px;
  }

  .engineered-precision__heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(2.1rem, 4vw, 3.15rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: #2E2C29;
    margin: 0 0 14px;
  }

  .engineered-precision__intro-text {
    font-family: var(--font-body--family);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: #706C63;
    margin: 0 auto;
    max-width: 34rem;
  }

  .engineered-precision__row {
    display: grid;
    grid-template-columns: 1fr;
    align-items: stretch;
    border-top: 1px solid rgba(46, 44, 41, 0.12);
    background: var(--ep-light-bg, #FFFFFF);
    color: var(--ep-light-fg, #2E2C29);
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.9s var(--animation-timing-fade-in, ease), transform 0.9s var(--animation-timing-fade-in, ease);

    @media screen and (min-width: 900px) {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }

  .engineered-precision__row.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .engineered-precision__row--dark {
    background: var(--ep-dark-bg, #211F1C);
    color: var(--ep-dark-fg, #F2EFE9);
    border-top-color: rgba(242, 239, 233, 0.14);
  }

  @media screen and (min-width: 900px) {
    .engineered-precision__row--reverse {
      & .engineered-precision__text {
        order: 2;
      }

      & .engineered-precision__diagram {
        order: 1;
      }
    }
  }

  .engineered-precision__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(36px, 5vw, 60px) clamp(20px, 5vw, 64px);
  }

  .engineered-precision__spec {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid currentColor;
    opacity: 0.9;
    max-width: 320px;
  }

  .engineered-precision__spec-code,
  .engineered-precision__fig {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.65;
  }

  .engineered-precision__panel-heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(1.7rem, 2.3vw, 2.15rem);
    line-height: 1.12;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
    max-width: 18ch;
  }

  .engineered-precision__panel-body {
    font-family: var(--font-body--family);
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.78;
    margin: 0;
    max-width: 34ch;
  }

  .engineered-precision__datasheet {
    margin: 22px 0 0;
    padding-top: 18px;
    border-top: 1px solid currentColor;
    opacity: 0.9;
    max-width: 34ch;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .engineered-precision__datasheet-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 9px 0;
    border-bottom: 1px dashed currentColor;
    opacity: 0.85;
  }

  .engineered-precision__datasheet-row:last-child {
    border-bottom: none;
  }

  .engineered-precision__datasheet-row dt {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.55;
    margin: 0;
    white-space: nowrap;
  }

  .engineered-precision__datasheet-row dd {
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
    text-align: right;
    margin: 0;
    opacity: 0.92;
  }

  .engineered-precision__diagram {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(20px, 3vw, 36px);
    min-height: 240px;
  }

  .engineered-precision__diagram-frame {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 11 / 10;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid currentColor;
    opacity: 0.94;
    position: relative;
  }

  .engineered-precision__diagram-frame::before {
    content: '';
    position: absolute;
    inset: 8px;
    border: 1px solid currentColor;
    opacity: 0.28;
    pointer-events: none;
  }

  .engineered-precision__scale-tick {
    position: absolute;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: currentColor;
    opacity: 0.2;
  }

  .engineered-precision__scale-tick--left {
    left: 20%;
  }

  .engineered-precision__scale-tick--right {
    right: 20%;
  }

  .ep-diagram {
    width: 90%;
    height: 90%;
    color: currentColor;
  }

  .ep-diagram-label {
    font-family: var(--font-accent--family);
    font-size: 6.25px;
    letter-spacing: 0.06em;
    fill: currentColor;
    opacity: 0.62;
  }

  .ep-fill {
    fill: currentColor;
  }

  .ep-fill-solid {
    fill: currentColor;
    fill-opacity: 0.06;
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    .ep-draw {
      stroke-dasharray: 240;
      stroke-dashoffset: 240;
      transition: stroke-dashoffset 1.4s var(--animation-timing-fade-in, ease) 0.2s;
    }

    .is-visible .ep-draw {
      stroke-dashoffset: 0;
    }
  }

  .engineered-precision__cta {
    text-align: center;
    padding: clamp(40px, 5vw, 64px) clamp(20px, 5vw, 64px);
    border-top: 1px solid rgba(46, 44, 41, 0.12);
  }

  .engineered-precision__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2E2C29;
    text-decoration: none;
    padding-bottom: 5px;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.25s ease, gap 0.25s ease;
  }

  .engineered-precision__cta-link:hover {
    opacity: 0.6;
    gap: 13px;
  }

  .engineered-precision__cta-link svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Engineered panels",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Engineering Philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Engineered Without Compromise."
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro text",
      "default": "Four principles guide every object we build — none of them negotiable."
    },
    {
      "type": "header",
      "content": "Row colors"
    },
    {
      "type": "color",
      "id": "light_background",
      "label": "Light row background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "light_foreground",
      "label": "Light row text",
      "default": "#2E2C29"
    },
    {
      "type": "color",
      "id": "dark_background",
      "label": "Dark row background",
      "default": "#211F1C"
    },
    {
      "type": "color",
      "id": "dark_foreground",
      "label": "Dark row text",
      "default": "#F2EFE9"
    },
    {
      "type": "header",
      "content": "Collection link"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link label",
      "default": "View The Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "text",
          "id": "spec_code",
          "label": "Spec code",
          "default": "MAT / 304-SS"
        },
        {
          "type": "text",
          "id": "fig_number",
          "label": "Figure number",
          "default": "FIG. 01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Every Component, Considered."
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Precision-milled from raw stainless steel and assembled by hand."
        },
        {
          "type": "header",
          "content": "Datasheet rows (format: Label — Value)"
        },
        {
          "type": "text",
          "id": "spec_line_1",
          "label": "Spec row 1"
        },
        {
          "type": "text",
          "id": "spec_line_2",
          "label": "Spec row 2"
        },
        {
          "type": "text",
          "id": "spec_line_3",
          "label": "Spec row 3"
        },
        {
          "type": "select",
          "id": "diagram",
          "label": "Diagram",
          "options": [
            { "value": "craftsmanship", "label": "Craftsmanship" },
            { "value": "materials", "label": "Materials" },
            { "value": "engineering", "label": "Engineering" },
            { "value": "timeless", "label": "Timeless design" }
          ],
          "default": "craftsmanship"
        },
        {
          "type": "select",
          "id": "row_theme",
