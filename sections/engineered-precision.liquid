{% liquid
  assign light_bg = section.settings.light_background
  assign light_fg = section.settings.light_foreground
  assign dark_bg = section.settings.dark_background
  assign dark_fg = section.settings.dark_foreground
%}

<div
  class="section section--full-width engineered-precision spacing-style"
  style="{% render 'spacing-style', settings: section.settings %} --ep-light-bg: {{ light_bg }}; --ep-light-fg: {{ light_fg }}; --ep-dark-bg: {{ dark_bg }}; --ep-dark-fg: {{ dark_fg }};"
  data-testid="engineered-precision"
>
  <div class="engineered-precision__intro">
    {% if section.settings.eyebrow != blank %}
      <p class="engineered-precision__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="engineered-precision__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.intro_text != blank %}
      <p class="engineered-precision__intro-text">{{ section.settings.intro_text }}</p>
    {% endif %}
  </div>

  <div class="engineered-precision__rows">
    {% for block in section.blocks %}
      {% liquid
        assign is_dark = false
        if block.settings.row_theme == 'dark'
          assign is_dark = true
        endif
        assign is_reverse = false
        if forloop.index0 == 1 or forloop.index0 == 3
          assign is_reverse = true
        endif
      %}
      <div
        class="engineered-precision__row{% if is_dark %} engineered-precision__row--dark{% endif %}{% if is_reverse %} engineered-precision__row--reverse{% endif %}"
        {{ block.shopify_attributes }}
      >
        <div class="engineered-precision__text">
          <div class="engineered-precision__spec">
            {% if block.settings.spec_code != blank %}
              <span class="engineered-precision__spec-code">{{ block.settings.spec_code }}</span>
            {% endif %}
            {% if block.settings.fig_number != blank %}
              <span class="engineered-precision__fig">{{ block.settings.fig_number }}</span>
            {% endif %}
          </div>
          {% if block.settings.heading != blank %}
            <h3 class="engineered-precision__panel-heading">{{ block.settings.heading }}</h3>
          {% endif %}
          {% if block.settings.body != blank %}
            <p class="engineered-precision__panel-body">{{ block.settings.body }}</p>
          {% endif %}
        </div>

        <div class="engineered-precision__diagram">
          <div class="engineered-precision__diagram-frame">
            {% case block.settings.diagram %}
              {% when 'craftsmanship' %}
                <svg class="ep-diagram" viewBox="0 0 240 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="86" y="78" width="68" height="44" rx="1" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <line x1="86" y1="60" x2="86" y2="140" class="ep-draw" stroke="currentColor" stroke-width="0.75" stroke-dasharray="2 3"/>
                  <line x1="154" y1="60" x2="154" y2="140" class="ep-draw" stroke="currentColor" stroke-width="0.75" stroke-dasharray="2 3"/>
                  <line x1="86" y1="50" x2="154" y2="50" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <line x1="86" y1="46" x2="86" y2="54" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <line x1="154" y1="46" x2="154" y2="54" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <text x="120" y="40" text-anchor="middle" class="ep-diagram-label">68.00mm</text>
                  <circle cx="98" cy="90" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <circle cx="142" cy="90" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <circle cx="98" cy="110" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <circle cx="142" cy="110" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <path d="M60 100 L78 100" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <path d="M162 100 L180 100" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <path d="M60 92 L60 108" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <path d="M180 92 L180 108" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                </svg>
              {% when 'materials' %}
                <svg class="ep-diagram" viewBox="0 0 240 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <line x1="52" y1="66" x2="188" y2="66" class="ep-draw" stroke="currentColor" stroke-width="0.75"/>
                  <rect x="52" y="82" width="40" height="40" class="ep-draw ep-fill-solid" stroke="currentColor" stroke-width="1"/>
                  <circle cx="120" cy="102" r="20" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <path d="M168 82 L188 82 L188 122 L168 122 Z" class="ep-draw" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3"/>
                  <text x="72" y="138" text-anchor="middle" class="ep-diagram-label">304-SS</text>
                  <text x="120" y="138" text-anchor="middle" class="ep-diagram-label">GLASS</text>
                  <text x="178" y="138" text-anchor="middle" class="ep-diagram-label">STEEL</text>
                  <line x1="52" y1="150" x2="188" y2="150" class="ep-draw" stroke="currentColor" stroke-width="0.75"/>
                </svg>
              {% when 'engineering' %}
                <svg class="ep-diagram" viewBox="0 0 240 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <ellipse cx="120" cy="54" rx="46" ry="10" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <ellipse cx="120" cy="84" rx="38" ry="9" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <ellipse cx="120" cy="112" rx="30" ry="8" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <ellipse cx="120" cy="138" rx="20" ry="6" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <line x1="74" y1="54" x2="74" y2="138" class="ep-draw" stroke="currentColor" stroke-width="0.75" stroke-dasharray="2 3"/>
                  <line x1="166" y1="54" x2="166" y2="138" class="ep-draw" stroke="currentColor" stroke-width="0.75" stroke-dasharray="2 3"/>
                  <line x1="120" y1="20" x2="120" y2="44" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <circle cx="120" cy="16" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <line x1="120" y1="148" x2="120" y2="172" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <circle cx="120" cy="176" r="2.5" class="ep-draw ep-fill" stroke="currentColor" stroke-width="1"/>
                  <text x="184" y="98" class="ep-diagram-label">04 STAGES</text>
                </svg>
              {% when 'timeless' %}
                <svg class="ep-diagram" viewBox="0 0 240 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="120" cy="100" r="64" class="ep-draw" stroke="currentColor" stroke-width="0.75" stroke-dasharray="1 4"/>
                  <path d="M104 56 C104 50 136 50 136 56 L140 128 C140 148 100 148 100 128 Z" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <line x1="112" y1="70" x2="128" y2="70" class="ep-draw" stroke="currentColor" stroke-width="0.75"/>
                  <line x1="80" y1="164" x2="160" y2="164" class="ep-draw" stroke="currentColor" stroke-width="1"/>
                  <text x="120" y="184" text-anchor="middle" class="ep-diagram-label">EST. PERMANENT</text>
                </svg>
            {% endcase %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% javascript %}
  (function () {
    if (window.__epRevealInit) return;
    window.__epRevealInit = true;

    const reduceMotion =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const rows = document.querySelectorAll('.engineered-precision__row');

    if (!rows.length) return;

    if (reduceMotion || !('IntersectionObserver' in window)) {
      rows.forEach((row) => row.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.18, rootMargin: '0px 0px -8% 0px' }
    );

    rows.forEach((row) => io.observe(row));
  })();
{% endjavascript %}

{% stylesheet %}
  .engineered-precision {
    background: var(--ep-light-bg, #F7F5F0);
    overflow: hidden;
  }

  .engineered-precision__intro {
    max-width: 46rem;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
    padding-bottom: clamp(48px, 6vw, 88px);
    text-align: center;
  }

  .engineered-precision__eyebrow {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #706C63;
    margin: 0 0 20px;
  }

  .engineered-precision__heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: #2E2C29;
    margin: 0 0 20px;
  }

  .engineered-precision__intro-text {
    font-family: var(--font-body--family);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: #706C63;
    margin: 0 auto;
    max-width: 34rem;
  }

  .engineered-precision__row {
    display: grid;
    grid-template-columns: 1fr;
    align-items: stretch;
    border-top: 1px solid rgba(46, 44, 41, 0.12);
    background: var(--ep-light-bg, #F7F5F0);
    color: var(--ep-light-fg, #2E2C29);
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.9s var(--animation-timing-fade-in, ease), transform 0.9s var(--animation-timing-fade-in, ease);

    @media screen and (min-width: 900px) {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }

  .engineered-precision__row.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .engineered-precision__row--dark {
    background: var(--ep-dark-bg, #211F1C);
    color: var(--ep-dark-fg, #F2EFE9);
    border-top-color: rgba(242, 239, 233, 0.14);
  }

  @media screen and (min-width: 900px) {
    .engineered-precision__row--reverse {
      & .engineered-precision__text {
        order: 2;
      }

      & .engineered-precision__diagram {
        order: 1;
      }
    }
  }

  .engineered-precision__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(48px, 7vw, 96px) clamp(20px, 6vw, 88px);
  }

  .engineered-precision__spec {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 28px;
    padding-bottom: 14px;
    border-bottom: 1px solid currentColor;
    opacity: 0.9;
    max-width: 320px;
  }

  .engineered-precision__spec-code,
  .engineered-precision__fig {
    font-family: var(--font-accent--family);
    font-weight: var(--font-accent--weight);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.65;
  }

  .engineered-precision__panel-heading {
    font-family: var(--font-heading--family);
    font-weight: 600;
    font-size: clamp(1.85rem, 2.6vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 18px;
    max-width: 18ch;
  }

  .engineered-precision__panel-body {
    font-family: var(--font-body--family);
    font-size: 1.0625rem;
    line-height: 1.65;
    opacity: 0.78;
    margin: 0;
    max-width: 32ch;
  }

  .engineered-precision__diagram {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(32px, 5vw, 64px);
    min-height: 280px;
  }

  .engineered-precision__diagram-frame {
    width: 100%;
    max-width: 340px;
    aspect-ratio: 6 / 5;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid currentColor;
    opacity: 0.94;
    position: relative;
  }

  .engineered-precision__diagram-frame::before {
    content: '';
    position: absolute;
    inset: 10px;
    border: 1px solid currentColor;
    opacity: 0.28;
    pointer-events: none;
  }

  .ep-diagram {
    width: 74%;
    height: 74%;
    color: currentColor;
  }

  .ep-diagram-label {
    font-family: var(--font-accent--family);
    font-size: 6.5px;
    letter-spacing: 0.08em;
    fill: currentColor;
    opacity: 0.6;
  }

  .ep-fill {
    fill: currentColor;
  }

  .ep-fill-solid {
    fill: currentColor;
    fill-opacity: 0.06;
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    .ep-draw {
      stroke-dasharray: 240;
      stroke-dashoffset: 240;
      transition: stroke-dashoffset 1.4s var(--animation-timing-fade-in, ease) 0.2s;
    }

    .is-visible .ep-draw {
      stroke-dashoffset: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Engineered panels",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Engineering Philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Engineered Without Compromise."
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro text",
      "default": "Four principles guide every object we build — none of them negotiable."
    },
    {
      "type": "header",
      "content": "Row colors"
    },
    {
      "type": "color",
      "id": "light_background",
      "label": "Light row background",
      "default": "#F7F5F0"
    },
    {
      "type": "color",
      "id": "light_foreground",
      "label": "Light row text",
      "default": "#2E2C29"
    },
    {
      "type": "color",
      "id": "dark_background",
      "label": "Dark row background",
      "default": "#211F1C"
    },
    {
      "type": "color",
      "id": "dark_foreground",
      "label": "Dark row text",
      "default": "#F2EFE9"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "text",
          "id": "spec_code",
          "label": "Spec code",
          "default": "MAT / 304-SS"
        },
        {
          "type": "text",
          "id": "fig_number",
          "label": "Figure number",
          "default": "FIG. 01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Every Component, Considered."
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Precision-milled from raw stainless steel and assembled by hand."
        },
        {
          "type": "select",
          "id": "diagram",
          "label": "Diagram",
          "options": [
            { "value": "craftsmanship", "label": "Craftsmanship" },
            { "value": "materials", "label": "Materials" },
            { "value": "engineering", "label": "Engineering" },
            { "value": "timeless", "label": "Timeless design" }
          ],
          "default": "craftsmanship"
        },
        {
          "type": "select",
          "id": "row_theme",
          "label": "Row theme",
          "options": [
            { "value": "light", "label": "Light" },
            { "value": "dark", "label": "Dark" }
          ],
          "default": "light"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Engineered panels",
      "blocks": [
        {
          "type": "panel",
          "settings": {
            "spec_code": "MAT / 304-SS",
            "fig_number": "FIG. 01",
            "heading": "Every Component, Considered.",
            "body": "Precision-milled from raw stainless steel and assembled by hand.",
            "diagram": "craftsmanship",
            "row_theme": "light"
          }
        },
        {
          "type": "panel",
          "settings": {
            "spec_code": "MAT / COMPOSITION",
            "fig_number": "FIG. 02",
            "heading": "Materials That Outlast Trends.",
            "body": "304 stainless steel and architectural glass — nothing plastic, nothing temporary.",
            "diagram": "materials",
            "row_theme": "dark"
          }
        },
        {
          "type": "panel",
          "settings": {
            "spec_code": "ENG / FILTRATION",
            "fig_number": "FIG. 03",
            "heading": "Engineered For Silence.",
            "body": "Multi-stage filtration tuned to disappear into daily life.",
            "diagram": "engineering",
            "row_theme": "light"
          }
        },
        {
          "type": "panel",
          "settings": {
            "spec_code": "FORM / LONGEVITY",
            "fig_number": "FIG. 04",
            "heading": "Designed To Never Go Out Of Style.",
            "body": "A form language built on restraint, made to sit quietly in any home for decades.",
            "diagram": "timeless",
            "row_theme": "dark"
          }
        }
      ]
    }
  ]
}
{% endschema %}
