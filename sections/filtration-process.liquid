        <line x1="170" y1="52" x2="170" y2="70" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="0.75"/>
        <text x="390" y="46" text-anchor="middle" class="fp-diagram-tag">02</text>
        <line x1="390" y1="52" x2="390" y2="70" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="0.75"/>
        <text x="610" y="46" text-anchor="middle" class="fp-diagram-tag">03</text>
        <line x1="610" y1="52" x2="610" y2="70" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="0.75"/>
        <text x="830" y="46" text-anchor="middle" class="fp-diagram-tag">04</text>
        <line x1="830" y1="52" x2="830" y2="70" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="0.75"/>

        <circle cx="112" cy="96" r="2.4" class="fp-draw fp-fill" pathLength="1" stroke="currentColor" stroke-width="1"/>
        <circle cx="142" cy="131" r="3" class="fp-draw fp-fill" pathLength="1" stroke="currentColor" stroke-width="1"/>
        <circle cx="172" cy="104" r="2.2" class="fp-draw fp-fill" pathLength="1" stroke="currentColor" stroke-width="1"/>
        <circle cx="202" cy="136" r="2.6" class="fp-draw fp-fill" pathLength="1" stroke="currentColor" stroke-width="1"/>
        <circle cx="232" cy="100" r="2.8" class="fp-draw fp-fill" pathLength="1" stroke="currentColor" stroke-width="1"/>
        <circle cx="248" cy="130" r="1.8" class="fp-draw fp-fill" pathLength="1" stroke="currentColor" stroke-width="1"/>

        <path d="M320 90 L335 110" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="0.9"/>
        <path d="M350 95 L365 115" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="0.9"/>
        <path d="M380 90 L395 110" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="0.9"/>
        <path d="M410 95 L425 115" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="0.9"/>
        <path d="M440 90 L455 110" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="0.9"/>
        <path d="M335 128 L350 148" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="0.9"/>
        <path d="M395 128 L410 148" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="0.9"/>

        <path d="M550 105 L554 109 L550 113 L546 109 Z" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="1"/>
        <path d="M580 128 L584 132 L580 136 L576 132 Z" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="1"/>
        <path d="M610 98 L614 102 L610 106 L606 102 Z" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="1"/>
