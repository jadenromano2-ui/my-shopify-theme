{% liquid
  assign bg = section.settings.background_color
  assign fg = section.settings.foreground_color
%}

<div
  class="section section--full-width filtration-process spacing-style"
  style="{% render 'spacing-style', settings: section.settings %} --fp-bg: {{ bg }}; --fp-fg: {{ fg }};"
  data-testid="filtration-process"
>
  <div class="filtration-process__intro">
    {% if section.settings.eyebrow != blank %}
      <p class="filtration-process__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="filtration-process__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.intro_text != blank %}
      <p class="filtration-process__intro-text">{{ section.settings.intro_text }}</p>
    {% endif %}
  </div>

  <div class="filtration-process__diagram-wrap">
