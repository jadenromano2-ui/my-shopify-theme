        <path d="M48 108 L58 115 L48 122" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="1.1"/>
        <text x="34" y="145" text-anchor="middle" class="fp-diagram-label">RAW INTAKE</text>

        <rect x="60" y="70" width="880" height="90" rx="6" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="1.2"/>
        <line x1="280" y1="70" x2="280" y2="160" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="1"/>
        <line x1="500" y1="70" x2="500" y2="160" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="1"/>
        <line x1="720" y1="70" x2="720" y2="160" class="fp-draw" pathLength="1" stroke="currentColor" stroke-width="1"/>

