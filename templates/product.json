                  "blocks": {
                    "body": {
                      "type": "text",
                      "name": "Body",
                      "settings": {
                        "text": "<p>Every component is covered for 15 years, full stop — no fine print, no prorated coverage. If a covered defect appears, we repair or replace the affected part at no cost to you.</p>",
