        "text_intro": {
          "type": "text",
          "settings": {
            "text": "<p>Most owners are done start to finish in under 15 minutes — here's exactly what that looks like, so there's no surprise waiting when the box arrives.</p>",
            "width": "100%",
            "max_width": "narrow",
            "alignment": "center",
            "type_preset": "rte",
            "font": "var(--font-body--family)",
            "font_size": "1.0625rem",
