            "custom_liquid": "<div id=\"hs-spec-sheet\" style=\"max-width:760px; margin:36px auto 0; padding-inline: clamp(4px, 2vw, 16px); border:1px solid #C8D1CC;\">\n  <div style=\"display:flex; align-items:center; justify-content:space-between; padding:20px 24px; border-bottom:1px solid #C8D1CC;\">\n    <span style=\"font-family: ui-monospace, monospace; font-size:0.6875rem; letter-spacing:0.08em; text-transform:uppercase; color:#8B9398;\">Spec Sheet</span>\n    <span style=\"font-family: ui-monospace, monospace; font-size:0.6875rem; letter-spacing:0.08em; text-transform:uppercase; color:#8B9398;\">Rev. A</span>\n  </div>\n  <div style=\"padding:8px 24px;\">\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Filtration Stages</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">4-Stage Sequential</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Filtration Media</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">Ceramic + Carbon Block</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Shell Material</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">304 Stainless Steel</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Final Filtration Precision</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">0.5 Micron</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Chlorine &amp; Odor Reduction</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">99.9%</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Flow Rate</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">2.5 L / min</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Cartridge Life</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">~6 Months</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Certification</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">NSF/ANSI 42 &amp; 53</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Independent Testing</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">500+ Hrs, Per-Unit Pressure Test</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Installation</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">No Plumber, &lt; 15 Min</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Warranty</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">15 Years</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px dashed #C8D1CC;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">Trial Period</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right;\">100 Nights</span></div>\n    <div style=\"display:flex; justify-content:space-between; gap:16px; padding:14px 0;\"><span style=\"font-family: var(--font-body--family); font-size:0.875rem; color:#5C6368;\">What's Included</span><span style=\"font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#202224; text-align:right; max-width:55%;\">Unit, Cartridge, Hardware, Setup Guide</span></div>\n  </div>\n</div>"
          },
