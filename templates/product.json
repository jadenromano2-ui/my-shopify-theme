          "blocks": {}
        },
        "text_intro": {
          "type": "text",
          "settings": {
            "text": "<p>What actually changes after the sale — how to know it needs attention, and how to keep it performing exactly like day one, for years.</p>",
            "width": "100%",
            "max_width": "narrow",
            "alignment": "center",
            "type_preset": "rte",
            "font": "var(--font-body--family)",
            "font_size": "1.0625rem",
            "line_height": "normal",
            "letter_spacing": "normal",
            "case": "none",
            "wrap": "pretty",
            "text_color": "#5c6368",
            "background": false,
            "background_color": "#00000026",
            "corner_radius": 0,
            "padding-block-start": 10,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "custom_liquid_content": {
          "type": "custom-liquid",
          "settings": {
            "custom_liquid": "<div id=\"hs-care-maintenance\" style=\"max-width:760px; margin:36px auto 0; padding-inline: clamp(4px, 2vw, 16px);\">\n  <div style=\"display:flex; flex-direction:column; gap:0;\">\n    <div style=\"display:flex; gap:18px; padding:20px 0; border-bottom:1px solid #C8D1CC;\">\n      <svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"flex-shrink:0; margin-top:2px;\"><circle cx=\"12\" cy=\"12\" r=\"9\" stroke=\"#0F5E75\" stroke-width=\"1.3\"/><path d=\"M12 7v5l3 2\" stroke=\"#0F5E75\" stroke-width=\"1.3\" stroke-linecap=\"round\"/></svg>\n      <div>\n        <h4 style=\"margin:0 0 6px; font-family: var(--font-heading--family); font-weight:600; font-size:1.0625rem; color:#202224;\">Knowing When To Replace The Cartridge</h4>\n        <p style=\"margin:0; font-family: var(--font-body--family); font-size:0.9375rem; line-height:1.65; color:#5C6368; max-width:34rem;\">Each cartridge is engineered for about 6 months of normal household use. If flow slows down or taste starts to shift before then, that's your cue too — don't wait for a hard failure to swap it.</p>\n      </div>\n    </div>\n    <div style=\"display:flex; gap:18px; padding:20px 0; border-bottom:1px solid #C8D1CC;\">\n      <svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"flex-shrink:0; margin-top:2px;\"><path d=\"M7 3h10l-1 8H8L7 3z\" stroke=\"#0F5E75\" stroke-width=\"1.3\"/><path d=\"M8 11l-1 10h10l-1-10\" stroke=\"#0F5E75\" stroke-width=\"1.3\"/></svg>\n      <div>\n        <h4 style=\"margin:0 0 6px; font-family: var(--font-heading--family); font-weight:600; font-size:1.0625rem; color:#202224;\">Cleaning The Exterior</h4>\n        <p style=\"margin:0; font-family: var(--font-body--family); font-size:0.9375rem; line-height:1.65; color:#5C6368; max-width:34rem;\">Wipe down with a damp cloth as needed. No harsh chemicals, no disassembly required — the 304 stainless steel body is built to shrug off daily use without special care.</p>\n      </div>\n    </div>\n    <div style=\"display:flex; gap:18px; padding:20px 0; border-bottom:1px solid #C8D1CC;\">\n      <svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"flex-shrink:0; margin-top:2px;\"><path d=\"M12 3v6M12 3l-4 4M12 3l4 4\" stroke=\"#0F5E75\" stroke-width=\"1.3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M5 13a7 7 0 0014 0\" stroke=\"#0F5E75\" stroke-width=\"1.3\"/></svg>\n      <div>\n        <h4 style=\"margin:0 0 6px; font-family: var(--font-heading--family); font-weight:600; font-size:1.0625rem; color:#202224;\">If Flow Slows Down</h4>\n        <p style=\"margin:0; font-family: var(--font-body--family); font-size:0.9375rem; line-height:1.65; color:#5C6368; max-width:34rem;\">Usually a sign the cartridge has reached the end of its service life. Check how long it's been installed first — if it's near or past 6 months, that's almost always the fix.</p>\n      </div>\n    </div>\n    <div style=\"display:flex; gap:18px; padding:20px 0;\">\n      <svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"flex-shrink:0; margin-top:2px;\"><rect x=\"5\" y=\"7\" width=\"14\" height=\"12\" rx=\"1.5\" stroke=\"#0F5E75\" stroke-width=\"1.3\"/><path d=\"M9 7V5a3 3 0 016 0v2\" stroke=\"#0F5E75\" stroke-width=\"1.3\"/></svg>\n      <div>\n        <h4 style=\"margin:0 0 6px; font-family: var(--font-heading--family); font-weight:600; font-size:1.0625rem; color:#202224;\">Not Using It For A While?</h4>\n        <p style=\"margin:0; font-family: var(--font-body--family); font-size:0.9375rem; line-height:1.65; color:#5C6368; max-width:34rem;\">If it'll sit unused for more than a couple weeks (travel, seasonal home), run water through it for about a minute before your next use rather than letting it sit stagnant.</p>\n      </div>\n    </div>\n  </div>\n  <p style=\"margin:24px auto 0; text-align:center; font-family: var(--font-body--family); font-size:0.9375rem; color:#5C6368;\">Still have a question about your system? <a href=\"/pages/contact\" style=\"color:#0F5E75;\">Reach out</a> — real support, not a bot.</p>\n</div>"
          },
          "blocks": {}
        }
