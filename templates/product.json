        "custom_liquid_content": {
          "type": "custom-liquid",
          "settings": {
            "custom_liquid": "<div id=\"hs-install-guide\" style=\"max-width:1040px; margin:36px auto 0; padding-inline: clamp(4px, 2vw, 16px);\">\n  <div style=\"display:grid; grid-template-columns: repeat(2, 1fr); gap:32px;\">\n    <style>\n      @media screen and (min-width: 900px) {\n        #hs-install-guide > div { grid-template-columns: repeat(4, 1fr); }\n      }\n    </style>\n    <div>\n      <div style=\"display:flex; align-items:center; gap:10px; margin-bottom:14px;\">\n        <span style=\"display:flex; align-items:center; justify-content:center; width:30px; height:30px; border:1px solid #0F5E75; border-radius:50%; font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#0F5E75; flex-shrink:0;\">01</span>\n        <span style=\"height:1px; flex:1; background:#C8D1CC;\"></span>\n      </div>\n      <svg viewBox=\"0 0 100 90\" width=\"100%\" style=\"max-width:140px; color:#0F5E75;\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n        <path d=\"M30 20 L30 55\" stroke=\"currentColor\" stroke-width=\"1.4\"/>\n        <circle cx=\"30\" cy=\"16\" r=\"6\" stroke=\"currentColor\" stroke-width=\"1.4\"/>\n        <path d=\"M24 16 L36 16\" stroke=\"currentColor\" stroke-width=\"1.2\"/>\n        <rect x=\"20\" y=\"55\" width=\"20\" height=\"14\" stroke=\"currentColor\" stroke-width=\"1.2\"/>\n        <path d=\"M50 20 L80 20 L80 40\" stroke=\"currentColor\" stroke-width=\"0.6\" stroke-dasharray=\"2 3\"/>\n      </svg>\n      <h4 style=\"margin:14px 0 6px; font-family: var(--font-heading--family); font-weight:600; font-size:1.0625rem; color:#202224;\">Shut Off The Water</h4>\n      <p style=\"margin:0; font-family: var(--font-body--family); font-size:0.875rem; line-height:1.6; color:#5C6368;\">Turn the supply valve under your sink to off. Takes a few seconds and avoids any mess during the swap.</p>\n    </div>\n    <div>\n      <div style=\"display:flex; align-items:center; gap:10px; margin-bottom:14px;\">\n        <span style=\"display:flex; align-items:center; justify-content:center; width:30px; height:30px; border:1px solid #0F5E75; border-radius:50%; font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#0F5E75; flex-shrink:0;\">02</span>\n        <span style=\"height:1px; flex:1; background:#C8D1CC;\"></span>\n      </div>\n      <svg viewBox=\"0 0 100 90\" width=\"100%\" style=\"max-width:140px; color:#0F5E75;\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n        <rect x=\"30\" y=\"30\" width=\"40\" height=\"30\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"1.4\"/>\n        <path d=\"M20 45 L30 45\" stroke=\"currentColor\" stroke-width=\"1.2\"/>\n        <path d=\"M70 45 L80 45\" stroke=\"currentColor\" stroke-width=\"1.2\"/>\n        <path d=\"M25 40 L25 50\" stroke=\"currentColor\" stroke-width=\"1.2\"/>\n        <path d=\"M75 40 L75 50\" stroke=\"currentColor\" stroke-width=\"1.2\"/>\n        <circle cx=\"50\" cy=\"45\" r=\"4\" stroke=\"currentColor\" stroke-width=\"1\" stroke-dasharray=\"1 2\"/>\n      </svg>\n      <h4 style=\"margin:14px 0 6px; font-family: var(--font-heading--family); font-weight:600; font-size:1.0625rem; color:#202224;\">Connect, Tool-Free</h4>\n      <p style=\"margin:0; font-family: var(--font-body--family); font-size:0.875rem; line-height:1.6; color:#5C6368;\">HAUSTAS connects to your standard fixture by hand — no wrenches, no plumber, no sealant required.</p>\n    </div>\n    <div>\n      <div style=\"display:flex; align-items:center; gap:10px; margin-bottom:14px;\">\n        <span style=\"display:flex; align-items:center; justify-content:center; width:30px; height:30px; border:1px solid #0F5E75; border-radius:50%; font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#0F5E75; flex-shrink:0;\">03</span>\n        <span style=\"height:1px; flex:1; background:#C8D1CC;\"></span>\n      </div>\n      <svg viewBox=\"0 0 100 90\" width=\"100%\" style=\"max-width:140px; color:#0F5E75;\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n        <rect x=\"40\" y=\"16\" width=\"20\" height=\"46\" rx=\"8\" stroke=\"currentColor\" stroke-width=\"1.4\"/>\n        <path d=\"M50 62 L50 76\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-dasharray=\"2 3\"/>\n        <path d=\"M44 70 L50 78 L56 70\" stroke=\"currentColor\" stroke-width=\"1.2\" fill=\"none\"/>\n        <line x1=\"45\" y1=\"26\" x2=\"45\" y2=\"52\" stroke=\"currentColor\" stroke-width=\"0.5\" stroke-dasharray=\"1 2\"/>\n      </svg>\n      <h4 style=\"margin:14px 0 6px; font-family: var(--font-heading--family); font-weight:600; font-size:1.0625rem; color:#202224;\">Seat The Cartridge</h4>\n      <p style=\"margin:0; font-family: var(--font-body--family); font-size:0.875rem; line-height:1.6; color:#5C6368;\">Your filter cartridge arrives pre-installed. On future swaps, it clicks into place — no twisting or guesswork.</p>\n    </div>\n    <div>\n      <div style=\"display:flex; align-items:center; gap:10px; margin-bottom:14px;\">\n        <span style=\"display:flex; align-items:center; justify-content:center; width:30px; height:30px; border:1px solid #0F5E75; border-radius:50%; font-family: ui-monospace, monospace; font-size:0.8125rem; font-weight:600; color:#0F5E75; flex-shrink:0;\">04</span>\n        <span style=\"height:1px; flex:1; background:#C8D1CC;\"></span>\n      </div>\n      <svg viewBox=\"0 0 100 90\" width=\"100%\" style=\"max-width:140px; color:#0F5E75;\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n        <path d=\"M40 20 L40 40 Q40 50 50 50 L65 50\" stroke=\"currentColor\" stroke-width=\"1.4\" fill=\"none\"/>\n        <path d=\"M60 45 L67 50 L60 55\" stroke=\"currentColor\" stroke-width=\"1.2\" fill=\"none\"/>\n        <path d=\"M67 55 L67 70\" stroke=\"currentColor\" stroke-width=\"1\" stroke-dasharray=\"2 2\"/>\n        <path d=\"M67 70 L64 65 M67 70 L70 65\" stroke=\"currentColor\" stroke-width=\"1\"/>\n      </svg>\n      <h4 style=\"margin:14px 0 6px; font-family: var(--font-heading--family); font-weight:600; font-size:1.0625rem; color:#202224;\">Flush &amp; Go</h4>\n      <p style=\"margin:0; font-family: var(--font-body--family); font-size:0.875rem; line-height:1.6; color:#5C6368;\">Run water for about 60 seconds to clear the new media, then it's ready. Start to finish, most owners are done in under 15 minutes.</p>\n    </div>\n  </div>\n</div>"
          },
          "blocks": {}
        }
