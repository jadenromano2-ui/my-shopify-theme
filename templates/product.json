                      "type": "text",
                      "name": "Body",
                      "settings": {
                        "text": "<p>Free standard shipping on every order within the contiguous United States. Every purchase ships with a 100-night trial — if it's not right for you, return it any time within 100 nights for a full refund, free of charge.</p>",
                        "width": "100%",
