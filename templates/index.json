    "ultrafiltration_01": {
      "type": "photo-spotlight",
      "settings": {
        "image_url": "https://cdn.shopify.com/s/files/1/0730/5648/5512/files/DA317700-CD94-456C-86D2-E799C0EC7AD4.png?v=1782787531",
        "image_alt": "HAUSTAS Pure ultrafiltration system",
        "image_position": "left",
        "eyebrow": "Ultrafiltration",
        "heading": "Membrane Filtration, Without The Waste.",
        "body_text": "Ultrafiltration pushes water through a hollow-fiber membrane with pores measured in nanometers — small enough to block sediment, bacteria, and cysts, while letting water flow through at full pressure. Unlike reverse osmosis, it produces zero wastewater and needs no electricity or drain line, so it fits anywhere a countertop can. HAUSTAS Pure and Pure One both run on this technology, paired with carbon and KDF stages for taste and heavy-metal reduction.",
        "background_color": "#FFFFFF",
        "foreground_color": "#2E2C29",
        "cta_label": "Shop The Pure One",
        "cta_link": "shopify://products/item-4",
        "padding-block-start": 72,
        "padding-block-end": 72
      }
    },
    "reverse_osmosis_01": {
      "type": "photo-spotlight",
      "settings": {
        "image_url": "https://cdn.shopify.com/s/files/1/0730/5648/5512/files/IMG-1860.png?v=1782843561",
        "image_alt": "HAUSTAS Reserve 2 reverse osmosis system",
        "image_position": "right",
        "eyebrow": "Reverse Osmosis",
        "heading": "The Most Thorough Filtration Available.",
        "body_text": "Reverse osmosis forces water through a semi-permeable membrane fine enough to reject dissolved solids, heavy metals, and other trace contaminants that lighter filtration methods can miss — typically the most complete filtration technology sold for home use. It runs under the sink, uses a small storage tank, and delivers filtered water on demand at the tap. HAUSTAS Reserve 2 pairs RO with a multi-stage pre-filter for full coverage.",
        "background_color": "#F3F7F6",
        "foreground_color": "#2E2C29",
        "cta_label": "Shop Reserve 2",
        "cta_link": "shopify://products/haustas-reserve-2",
        "padding-block-start": 72,
        "padding-block-end": 72
      }
    },
    "faucet_filtration_01": {
      "type": "photo-spotlight",
      "settings": {
        "image_url": "https://cdn.shopify.com/s/files/1/0730/5648/5512/files/29A191BE-EC2F-431A-8EF1-3C04C3346050.png?v=1782787254",
        "image_alt": "HAUSTAS Flow Pro faucet filtration system",
        "image_position": "left",
        "eyebrow": "Faucet Filtration",
        "heading": "Filtration Built Into The Faucet Itself.",
        "body_text": "Instead of a separate unit taking up counter or cabinet space, faucet filtration integrates the entire filtration stack directly into the faucet body — water is filtered the moment it leaves the tap. HAUSTAS Flow and Flow Pro add precision temperature control on top, so filtered water arrives at exactly the temperature you need, without a second appliance on the counter.",
