              "settings": {
                "custom_liquid": "{% liquid\n  assign p = closest.product\n  assign badge = p.metafields.custom.card_badge.value\n  assign desc = p.description | strip_html | strip_newlines\n%}\n{% if badge != blank %}\n  <span class=\"hs-card-badge\">{{ badge }}</span>\n{% endif %}\n{% if desc != blank %}\n  <p class=\"hs-card-desc\">{{ desc | truncatewords: 22 }}</p>\n{% endif %}\n<style>\n  #shopify-section-{{ closest.section.id }} .product-card {\n    position: relative;\n    transition: transform 0.25s ease, box-shadow 0.25s ease;\n  }\n  #shopify-section-{{ closest.section.id }} .product-card:hover {\n    transform: translateY(-4px);\n    box-shadow: 0 10px 24px rgba(46, 44, 41, 0.08);\n  }\n  #shopify-section-{{ closest.section.id }} .hs-card-badge {\n    position: absolute;\n    top: 20px;\n    right: 20px;\n    z-index: 2;\n    padding: 5px 10px;\n    background: #2E2C29;\n    color: #FFFFFF;\n    font-family: var(--font-accent--family);\n    font-weight: var(--font-accent--weight);\n    font-size: 0.6875rem;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    pointer-events: none;\n  }\n  #shopify-section-{{ closest.section.id }} .hs-card-desc {\n    margin: 0;\n    font-family: var(--font-body--family);\n    font-size: 0.9375rem;\n    line-height: 1.6;\n    color: #706C63;\n    display: -webkit-box;\n    -webkit-line-clamp: 2;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n  #shopify-section-{{ closest.section.id }} .hs-buy-now-btn {\n    transition: background-color 0.2s ease, border-color 0.2s ease;\n  }\n  #shopify-section-{{ closest.section.id }} .hs-buy-now-btn:hover {\n    background-color: #1F4448 !important;\n    border-color: #1F4448 !important;\n  }\n  #shopify-section-{{ closest.section.id }} .hs-buy-now-btn svg {\n    transition: transform 0.2s ease;\n  }\n  #shopify-section-{{ closest.section.id }} .hs-buy-now-btn:hover svg {\n    transform: translateX(3px);\n  }\n  #shopify-section-{{ closest.section.id }} .car